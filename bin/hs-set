#!/opt/homebrew/bin/bash

SCRIPT_DIR="$(dirname "$0")"
export PATH="/opt/homebrew/bin:$SCRIPT_DIR:$PATH"

_default() {
    for val in "$@"; do
        if [[ -n "$val" ]]; then
            echo "$val"
            return 0
        fi
    done
    return 1
}

_send_keys() {
    local lua_args=""
    local first=1
    for arg in "$@"; do
        if [[ $first -eq 1 ]]; then
            first=0
        else
            lua_args="$lua_args, "
        fi
        lua_args="$lua_args\"$arg\""
    done
    hs -c "Preset.sendKeys({$lua_args})"
}

_display_message() {
    local duration=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --duration) duration="$2"; shift 2 ;;
            --duration=*) duration="${1#--duration=}"; shift ;;
            --) shift; break ;;
            *) break ;;
        esac
    done
    local message="$1"
    message="${message//\\/\\\\}"
    message="${message//\"/\\\"}"
    duration=$(_default "$duration" "0.5")
    hs -c "Preset.displayMessage(\"$message\", $duration)"
}

_trigger_menu_bar() {
    local path="$1"
    hs -c "Preset.triggerMenuBar([=[$path]=])"
}

_get_active_app() {
    hs -c "Preset.getActiveApp()"
}

_get_selected_text() {
    hs -c "Preset.getSelectedText()"
}

_show_or_hide_app() {
    local only_show="false"
    local only_hide="false"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --only-show) only_show="true"; shift ;;
            --only-hide) only_hide="true"; shift ;;
            --) shift; break ;;
            *) break ;;
        esac
    done
    local app="$1"
    app="${app//\\/\\\\}"
    app="${app//\"/\\\"}"
    hs -c "Preset.showOrHideApp(\"$app\", $only_show, $only_hide)"
}

_show_app() {
    _show_or_hide_app --only-show "$@"
}

_alternate_app() {
    local app="$1"; shift
    local cmd="" hide="" minimize=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --cmd) cmd="$2"; shift 2 ;;
            --cmd=*) cmd="${1#--cmd=}"; shift ;;
            --hide) hide="true"; shift ;;
            --minimize) minimize="true"; shift ;;
            --) shift; break ;;
            *) break ;;
        esac
    done
    local app_escaped="${app//\\/\\\\}"
    app_escaped="${app_escaped//\"/\\\"}"
    local opts="{"
    [[ -n "$hide" ]] && opts="$opts hide=true,"
    [[ -n "$minimize" ]] && opts="$opts minimize=true,"
    if [[ -n "$cmd" ]]; then
        local cmd_escaped="${cmd//\\/\\\\}"
        cmd_escaped="${cmd_escaped//\"/\\\"}"
        opts="$opts cmd=\"$cmd_escaped\","
    fi
    opts="$opts}"
    hs -c "Preset.alternateApp(\"$app_escaped\", $opts)"
}

_get_key_codes() {
    printf "%s\n" "$@" | jq -Rsr '
        {
            "ctrl": 59, "shift": 56, "alt": 58, "cmd": 55,
            "a": 0, "b": 11, "c": 8, "d": 2, "e": 14, "f": 3,
            "g": 5, "h": 4, "i": 34, "j": 38, "k": 40, "l": 37,
            "m": 46, "n": 45, "o": 31, "p": 35, "q": 12, "r": 15,
            "s": 1, "t": 17, "u": 32, "v": 9, "w": 13, "x": 7,
            "y": 16, "z": 6, "space": 49, "return": 36, "left": 123,
            "right": 124, "up": 126, "down": 125, "fn": 63, "1": 18,
            "2": 19, "3": 20, "4": 21, "5": 23, "6": 22, "7": 26,
            "8": 28, "9": 25, "0": 29, "tab": 48, "escape": 53,
            "backtick": 50, "backslash": 42
        } as $map
        | rtrimstr("\n")
        | split("\n")
        | map(. as $key | $map[.] | if . == null then error("\($key) is not mapped") else . end)
        | join(",")
    '
}

preset="$1"; shift
case "$preset" in
    send-keys) _send_keys "$@" ;;
    display-message) _display_message "$@" ;;
    trigger-menu-bar) _trigger_menu_bar "$@" ;;
    get-active-app) _get_active_app ;;
    get-selected-text) _get_selected_text ;;
    show-or-hide-app) _show_or_hide_app "$@" ;;
    show-app) _show_app "$@" ;;
    alternate-app) _alternate_app "$@" ;;
    restart-btt) ;; # No-op
    get-key-codes) _get_key_codes "$@" ;;
    *) echo "command not found - $preset" >&2; exit 1 ;;
esac
