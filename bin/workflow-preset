#!/opt/homebrew/bin/fish --no-config
set -x PATH /opt/homebrew/bin (status dirname) $PATH

function workflow-preset

    set preset $argv[1]; set -e argv[1]

    switch "$preset"
    case "perform-default-ui"
        set app (hs-preset get-active-app)

        if test "$app" = "Google Chrome"
            hs-preset send-keys cmd shift a
        end
    case "*"
        return 1
    end
end

workflow-preset $argv
