#!/opt/homebrew/bin/fish --no-config
set -x PATH /opt/homebrew/bin (status dirname) $PATH

function svim-preset
    set mode $argv[1]
    set -e argv[1]

    switch "$mode"
    case "enter"
        svim > /tmp/svim.log &
        skhd -k "cmd - tab"
        skhd -k "cmd - tab"
    case "exit"
        killall svim
    end
end

svim-preset $argv
