#!/usr/bin/env -S fish --no-config
set -x PATH /opt/homebrew/bin (status dirname) $PATH

function hs-preset
    set preset $argv[1]
    set -e argv[1]

    switch "$preset"
    case "send-keys"
        # Build a Lua table from the arguments
        set -l lua_args
        for arg in $argv
            set -a lua_args "\"$arg\""
        end
        set -l lua_table (string join ", " $lua_args)
        hs -c "Preset.sendKeys({$lua_table})"

    case "display-message"
        argparse duration= -- $argv
        or return 1

        set -l message (string escape -- $argv[1])
        set -l duration (test -n "$_flag_duration"; and echo "$_flag_duration"; or echo 0.5)

        hs -c "Preset.displayMessage(\"$message\", $duration)"

    case "trigger-menu-bar"
        set -l path "$argv[1]"
        hs -c "Preset.triggerMenuBar([=[$path]=])"

    case "get-active-app"
        hs -c "Preset.getActiveApp()"

    case "show-or-hide-app"
        argparse only-show only-hide -- $argv
        or return 1

        set -l app (string escape -- $argv[1])
        set -l only_show "false"
        set -l only_hide "false"

        if set -q _flag_only_show
            set only_show "true"
        end

        if set -q _flag_only_hide
            set only_hide "true"
        end

        hs -c "Preset.showOrHideApp(\"$app\", $only_show, $only_hide)"

    case "show-app"
        hs-preset show-or-hide-app --only-show $argv

    case "alternate-app"
        set -l app $argv[1]
        set -e argv[1]

        argparse cmd= hide=? minimize=? -- $argv
        or return 1

        set -l app_escaped (string escape -- $app)
        set -l opts "{"

        if set -q _flag_hide
            set opts "$opts hide=true,"
        end

        if set -q _flag_minimize
            set opts "$opts minimize=true,"
        end

        if test -n "$_flag_cmd"
            set -l cmd_escaped (string escape -- $_flag_cmd)
            set opts "$opts cmd=\"$cmd_escaped\","
        end

        set opts "$opts}"

        hs -c "Preset.alternateApp(\"$app_escaped\", $opts)"

    case "restart-btt"
        # No-op: BTT is no longer used

    case "get-key-codes"
        printf "%s\n" $argv | jq -Rsr '
            {
                "ctrl": 59, "shift": 56, "alt": 58, "cmd": 55,
                "a": 0, "b": 11, "c": 8, "d": 2, "e": 14, "f": 3,
                "g": 5, "h": 4, "i": 34, "j": 38, "k": 40, "l": 37,
                "m": 46, "n": 45, "o": 31, "p": 35, "q": 12, "r": 15,
                "s": 1, "t": 17, "u": 32, "v": 9, "w": 13, "x": 7,
                "y": 16, "z": 6, "space": 49, "return": 36, "left": 123,
                "right": 124, "up": 126, "down": 125, "fn": 63, "1": 18,
                "2": 19, "3": 20, "4": 21, "5": 23, "6": 22, "7": 26,
                "8": 28, "9": 25, "0": 29, "tab": 48, "escape": 53,
                "backtick": 50, "backslash": 42
            } as $map
            | rtrimstr("\n")
            | split("\n")
            | map(. as $key | $map[.] | if . == null then error("\($key) is not mapped") else . end)
            | join(",")
        '

    case "focus-window-id"
        set -l window_id $argv[1]
        hs -c "Preset.focusWindowById($window_id)"

    case "window-exists"
        set -l window_id $argv[1]
        set -l result (hs -c "Preset.windowExists($window_id)")
        test "$result" = "true"
        return $status

    case "minimize-window"
        if test (count $argv) -gt 0
            hs -c "Preset.minimizeWindow($argv[1])"
        else
            hs -c "Preset.minimizeWindow()"
        end

    case "deminimize-last"
        hs -c "Preset.deminimizeLast()"

    case "deminimize-all"
        hs -c "Preset.deminimizeAll()"

    case "get-recent-window-id"
        hs -c "Preset.getRecentWindowId()"

    case "get-app-window-id"
        argparse 'match-title=' -- $argv
        or return 1

        set -l app_name (string escape -- $argv[1])
        if set -q _flag_match_title
            set -l title_pat (string escape -- $_flag_match_title)
            hs -c "Preset.getAppWindowId(\"$app_name\", \"$title_pat\")"
        else
            hs -c "Preset.getAppWindowId(\"$app_name\")"
        end

    case "focus-pid"
        hs -c "Preset.focusPid($argv[1])"

    case "minimize-pid"
        hs -c "Preset.minimizePid($argv[1])"

    case "focus-floating-window"
        set -l ids_json $argv[1]
        set -l focused_id $argv[2]
        set -l direction $argv[3]
        hs -c "Preset.focusFloatingWindow([=[$ids_json]=], $focused_id, \"$direction\")"

    case "snap-window"
        set -l direction $argv[1]
        hs -c "Preset.snapWindow(\"$direction\")"

    case "side-by-side"
        hs -c "Preset.sideBySide()"

    case "get-focused-window-id"
        hs -c "Preset.getFocusedWindowId()"

    case "get-focused-window-json"
        hs -c "Preset.getFocusedWindowJson()"

    case "get-all-windows-json"
        hs -c "Preset.getAllWindowsJson()"

    case "get-app-window-ids"
        set -l app_name (string escape -- $argv[1])
        hs -c "Preset.getAppWindowIds(\"$app_name\")"

    case "find-new-window"
        set -l app_name (string escape -- $argv[1])
        set -l old_ids (string escape -- $argv[2])
        hs -c "Preset.findNewWindow(\"$app_name\", \"$old_ids\")"

    case "watch-new-window"
        set -l app_name (string escape -- $argv[1])
        set -l callback_cmd (string escape -- $argv[2])
        hs -c "Preset.watchNewWindow(\"$app_name\", \"$callback_cmd\")"

    case '*'
        return 1
    end
end

hs-preset $argv
