#!/usr/bin/env -S fish --no-config
set -x PATH /opt/homebrew/bin (status dirname) $PATH

function osascript-preset
    set preset $argv[1]
    set -e argv[1]

    switch "$preset"
    case "send-keys"
        set -l modifiers
        set -l key

        for arg in $argv
            switch "$arg"
                case ctrl shift alt meta cmd fn
                    set -a modifiers $arg
                case '*'
                    set key $arg
            end
        end

        if test -z "$key"
            return 1
        end

        set -l key_code (osascript-preset get-key-codes "$key")
        or return 1

        set -l flags 0
        for m in $modifiers
            switch "$m"
                case cmd
                    set flags (math "$flags + 1048584")   # kCGEventFlagMaskCommand + NX_DEVICELCMDKEYMASK
                case alt meta
                    set flags (math "$flags + 524320")     # kCGEventFlagMaskAlternate + NX_DEVICELALTKEYMASK
                case ctrl
                    set flags (math "$flags + 262145")     # kCGEventFlagMaskControl + NX_DEVICELCTRLKEYMASK
                case shift
                    set flags (math "$flags + 131074")     # kCGEventFlagMaskShift + NX_DEVICELSHIFTKEYMASK
                case fn
                    set flags (math "$flags + 8388608")    # kCGEventFlagMaskSecondaryFn
            end
        end

        # Arrow keys require fn + numericpad flags to be recognized
        switch "$key"
            case left right up down
                if not contains fn $modifiers
                    set flags (math "$flags + 8388608")    # kCGEventFlagMaskSecondaryFn
                end
                set flags (math "$flags + 2097152")        # kCGEventFlagMaskNumericPad
        end

        /usr/bin/osascript -l JavaScript -e '
            ObjC.import("CoreGraphics");
            var down = $.CGEventCreateKeyboardEvent(null, '"$key_code"', true);
            $.CGEventSetFlags(down, '"$flags"');
            $.CGEventPost(1, down);
            var up = $.CGEventCreateKeyboardEvent(null, '"$key_code"', false);
            $.CGEventSetFlags(up, '"$flags"');
            $.CGEventPost(1, up);
        '

    case "display-message"
        argparse duration= -- $argv
        or return 1

        set -l message (string replace -a '"' '\\"' -- "$argv[1]")

        /usr/bin/osascript -e "display notification \"$message\" with title \"Preset\""

    case "trigger-menu-bar"
        argparse app= pid= -- $argv

        set -l path "$argv[1]"
        set app "$_flag_app"
        if test -z "$app"
            set app (osascript-preset get-active-app)
        end
        or return 1

        set -l app_escaped (string replace -a '"' '\\"' -- "$app")

        # Split semicolon-separated path into items
        set -l items (string split ";" -- "$path")
        set trimmed (string trim -- $items)

        if test (count $trimmed) -eq 0
            return 1
        end

        set escaped (string replace -a '"' '\\"' -- $trimmed)
        set items 'menu item "'$escaped[-1..2]'" of menu 1' "menu bar item \"$escaped[1]\" of menu bar 1"
        set chain (string join ' of ' $items)

        set -l process_ref
        if test -n "$_flag_pid"
            set process_ref "(first process whose unix id is $_flag_pid)"
        else
            set process_ref "process \"$app_escaped\""
        end
        set cmd "tell application \"System Events\" to tell $process_ref to click $chain"

        echo osascript -e (string escape $cmd)
        /usr/bin/osascript -e "$cmd" > /dev/null

    case "click-status-menu"
        # Click an item in an app's menu bar extra (status item next to the
        # clock). Path is semicolon-separated: first section is the process
        # name, the rest is the menu item path. Supports nested submenus, e.g.
        #   osascript-preset click-status-menu "AeroSpace;Quit AeroSpace"
        #   osascript-preset click-status-menu "Flux;Disable;For an hour"
        set -l path "$argv[1]"

        set -l sections (string trim -- (string split ";" -- "$path"))
        if test (count $sections) -lt 2
            echo "click-status-menu: expected \"App;Menu Item[;Submenu…]\"" >&2
            return 1
        end

        set -l escaped (string replace -a '"' '\\"' -- $sections)
        set -l app $escaped[1]
        set -l items $escaped[2..-1]

        # Build one click per level: open the status item, then click each
        # menu item in turn (opening submenus on the way down).
        set -l clicks "click"
        set -l suffix ""
        for item in $items
            if test -z "$suffix"
                set suffix "menu item \"$item\" of menu 1"
            else
                set suffix "menu item \"$item\" of menu 1 of $suffix"
            end
            set -a clicks "click $suffix"
        end

        set -l body (string join \n $clicks)
        set -l cmd "tell application \"System Events\" to tell process \"$app\"
            tell menu bar item 1 of menu bar 2
                $body
            end tell
        end tell"

        /usr/bin/osascript -e "$cmd" > /dev/null

    case "get-active-app"
        /usr/bin/osascript -e 'tell application "System Events" to get name of first application process whose frontmost is true'

    case "is-mission-control-active"
        # Print "true"/"false" and exit 0 when Mission Control is on screen,
        # non-zero otherwise, so it works both as `$(... )` and `if ...`.
        #
        # Detection: when Mission Control is closed the Dock process only owns
        # the desktop wallpaper window (a deeply negative window layer). While
        # Mission Control is up the Dock also owns the overlay backdrop and the
        # per-window preview tiles at layers 17-18. We look for a Dock-owned
        # window in that range (staying below the Dock bar's own level, 20, so a
        # visible Dock never false-positives). The classic Y == -1 heuristic no
        # longer holds on recent macOS.
        set -l result (/usr/bin/osascript -l JavaScript -e '
            ObjC.import("CoreGraphics");
            ObjC.import("Foundation");
            // CGWindowListCopyWindowInfo returns a CFArrayRef; castRefToObject
            // bridges it to a usable NSArray (CFBridgingRelease is inlined and
            // segfaults from JXA).
            var list = ObjC.castRefToObject(
                $.CGWindowListCopyWindowInfo($.kCGWindowListOptionOnScreenOnly, 0));
            var active = false;
            for (var i = 0; i < list.count; i++) {
                var entry = list.objectAtIndex(i);
                if (ObjC.unwrap(entry.objectForKey("kCGWindowOwnerName")) === "Dock") {
                    var layer = ObjC.unwrap(entry.objectForKey("kCGWindowLayer"));
                    if (layer >= 17 && layer < 20) { active = true; }
                }
            }
            active ? "true" : "false";
        ')
        or return 1

        echo $result
        test "$result" = true

    case "show-or-hide-app"
        argparse only-show only-hide -- $argv
        or return 1

        set -l app "$argv[1]"
        set -l app_escaped (string replace -a '"' '\\"' -- "$app")

        if set -q _flag_only_show
            /usr/bin/osascript -e "tell application \"$app_escaped\" to activate"
        else if set -q _flag_only_hide
            /usr/bin/osascript -e "tell application \"System Events\" to set visible of process \"$app_escaped\" to false"
        else
            # Toggle: check if frontmost, then hide or activate
            set -l frontmost (osascript-preset get-active-app)
            if test "$frontmost" = "$app"
                /usr/bin/osascript -e "tell application \"System Events\" to set visible of process \"$app_escaped\" to false"
            else
                /usr/bin/osascript -e "tell application \"$app_escaped\" to activate"
            end
        end

    case "show-app"
        osascript-preset show-or-hide-app --only-show $argv

    case "alternate-app"
        set -l app $argv[1]
        set -e argv[1]

        argparse cmd= hide=? minimize=? -- $argv
        or return 1

        set -l app_escaped (string replace -a '"' '\\"' -- "$app")

        # Check if app is frontmost
        set -l frontmost (osascript-preset get-active-app)

        if test "$frontmost" = "$app"
            if set -q _flag_hide
                /usr/bin/osascript -e "tell application \"System Events\" to set visible of process \"$app_escaped\" to false"
            else if set -q _flag_minimize
                /usr/bin/osascript -e "tell application \"System Events\" to tell process \"$app_escaped\" to set value of attribute \"AXMinimized\" of front window to true"
            end
        else
            if test -n "$_flag_cmd"
                fish -c "$_flag_cmd"
            else
                /usr/bin/osascript -e "tell application \"$app_escaped\" to activate"
            end
        end

    case "restart-btt"
        # No-op: BTT is no longer used

    case "get-key-codes"
        printf "%s\n" $argv | jq -Rsr '
            {
                "ctrl": 59, "shift": 56, "alt": 58, "cmd": 55,
                "a": 0, "b": 11, "c": 8, "d": 2, "e": 14, "f": 3,
                "g": 5, "h": 4, "i": 34, "j": 38, "k": 40, "l": 37,
                "m": 46, "n": 45, "o": 31, "p": 35, "q": 12, "r": 15,
                "s": 1, "t": 17, "u": 32, "v": 9, "w": 13, "x": 7,
                "y": 16, "z": 6, "space": 49, "return": 36, "left": 123,
                "right": 124, "up": 126, "down": 125, "fn": 63, "1": 18,
                "2": 19, "3": 20, "4": 21, "5": 23, "6": 22, "7": 26,
                "8": 28, "9": 25, "0": 29, "tab": 48, "escape": 53,
                "backtick": 50, "backslash": 42, "slash": 44
            } as $map
            | rtrimstr("\n")
            | split("\n")
            | map(. as $key | $map[.] | if . == null then error("\($key) is not mapped") else . end)
            | join(",")
        '

    case '*'
        return 1
    end
end

osascript-preset $argv
