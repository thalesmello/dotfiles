#!/bin/sh

duration_s=0.75

while [ $# -gt 0 ]; do
    case "$1" in
        -t|--time)
            case "$2" in
                ''|*[!0-9.]* | *.*.*)
                    echo "Error: --time requires a numeric value in seconds" >&2
                    exit 1
                    ;;
            esac
            duration_s="$2"
            shift 2
            ;;
        -h|--help)
            echo "Usage: display-message [-t seconds] <message>"
            echo ""
            echo "Display an alert message using Hammerspoon."
            echo ""
            echo "Options:"
            echo "  -t, --time <s>   Duration in seconds (default: 0.5)"
            echo "  -h, --help       Show this help message"
            exit 0
            ;;
        *)
            break
            ;;
    esac
done

hs -c "hs.alert.show([=[$1]=], $duration_s)" >/dev/null
