#!/opt/homebrew/bin/bash

SCRIPT_DIR="$(dirname "$0")"
export PATH="/opt/homebrew/bin:$SCRIPT_DIR:$PATH"

_new_window() {
    osascript -e 'tell application "iTerm2" to create window with default profile'
}

_is_floating_window_active() {
    [[ "$(hs -c '
        local w = hs.window.focusedWindow()
        if w and w:application():name() == "iTerm2" and w:title() == "floating-terminal" then
            print("yes")
        end
    ')" == "yes" ]]
}

_hide_floating_terminal() {
    _is_floating_window_active && osascript -e '
        tell application "iTerm2"
            hide hotkey window current window
        end tell
    '
}

preset="$1"; shift
case "$preset" in
    new-window) _new_window ;;
    is-floating-window-active) _is_floating_window_active ;;
    hide-floating-terminal) _hide_floating_terminal ;;
    *) exit 0 ;;
esac
