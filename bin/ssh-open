#!/bin/bash

# Opens a URL via iTerm2's OSC 1337 escape sequence.
# Useful when SSHed into a remote machine to open URLs on the local browser.

# tmux requires unrecognized OSC sequences to be wrapped with DCS tmux;
# <sequence> ST, and for all ESCs in <sequence> to be replaced with ESC ESC.
function print_osc() {
    if [[ $TERM == screen* ]] ; then
        printf "\033Ptmux;\033\033]"
    else
        printf "\033]"
    fi
}

function print_st() {
    if [[ $TERM == screen* ]] ; then
        printf "\a\033\\"
    else
        printf "\a"
    fi
}

if [ $# -eq 0 ]; then
    echo "Usage: ssh-open <url>" 1>&2
    exit 1
fi

url="$1"
encoded=$(echo -n "$url" | base64)

print_osc
printf "1337;OpenURL=:%s" "$encoded"
print_st
