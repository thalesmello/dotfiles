#!/opt/homebrew/bin/bash

SCRIPT_DIR="$(dirname "$0")"
export PATH="/opt/homebrew/bin:$SCRIPT_DIR:$PATH"

btt_url='http://localhost:12000/trigger_action/'

_contains() {
    local needle="$1"; shift
    for item in "$@"; do
        [[ "$item" == "$needle" ]] && return 0
    done
    return 1
}

_default() {
    for val in "$@"; do
        if [[ -n "$val" ]]; then
            echo "$val"
            return 0
        fi
    done
    return 1
}

_focus_window_id() {
    local window_id="$1"; shift
    yabai -m window --focus "$window_id"
}

_focus_window() {
    local direction="$1"; shift

    case "$direction" in
        next|prev)
            _focus_window_in_stack "$direction" \
            || _focus_window_in_space "$direction"
            return $?
            ;;
    esac

    local winid
    winid=$(yabai -m query --windows --space | jq --arg dir "$direction" '
    def hidden($under; $above):
    ($under.x >= $above.x
    and ($under.x + $under.w) <=($above.x + $above.w)
    and $under.y >= $above.y
    and ($under.y + $under.h) <= ($above.y + $above.h));

    def intersect($u; $a):
    if
            ($u.x >= ($a.x + $a.w)
            or ($u.x + $u.w) <= $a.x
            or ($u.y + $u.h) <= $a.y
            or $u.y >= ($a.y + $a.h)) then empty
    else
            ([$u.x, $a.x] | max) as $x
            | ([$u.y, $a.y] | max) as $y
            | (([$u.x + $u.w, $a.x + $a.w] | min) - $x) as $w
            | (([$u.y + $u.h, $a.y + $a.h] | min) - $y) as $h
            | {$x, $y, $w, $h}
    end;

    def visible_area($under_list; $many):
    $under_list
    | [.[0], .[1:]] as [$under, $tail]
    | if $under == null then 0
    elif ($many | any(hidden($under; .))) then visible_area($tail; $many)
    else (
            [first($many[] | intersect($under; .))] as [$i]
            | $under as $u
            | if $i == null then (($u.w * $u.h) + visible_area($tail; $many))
            else visible_area(([
                    {x: $u.x, y: $u.y, w: ($i.x - $u.x), h: ($i.y - $u.y)},
                    {x: $i.x, y: $u.y, w: $i.w, h: ($i.y - $u.y)},
                    {x: ($i.x + $i.w), y: $u.y, w: ($u.x + $u.w - $i.x - $i.w), h: ($i.y - $u.y)},
                    {x: $u.x, y: $i.y, w: ($i.x - $u.x), h: $i.h},
                    {x: $i.x, y: $i.y, w: $i.w, h: $i.h},
                    {x: ($i.x + $i.w), y: $i.y, w: ($u.x + $u.w - $i.x - $i.w), h: $i.h},
                    {x: $u.x, y: ($i.y + $i.h), w: ($i.x - $u.x), h: ($u.y + $u.h - $i.y - $i.h)},
                    {x: $i.x, y: ($i.y + $i.h), w: $i.w, h: ($u.y + $u.h - $i.y - $i.h)},
                    {x: ($i.x + $i.w), y: ($i.y + $i.h), w: ($u.x + $u.w - $i.x - $i.w), h: ($u.y + $u.h - $i.y - $i.h)}
            ]|map(select((.h>0) and (.w>0)))) + $tail; $many) end
    )
    end;
    .
    | map(select(."is-visible" and (."is-sticky"|not)))
    | reverse
    | with_entries(.value += {z_index: .key} | .key |= "key_\(.)")
    | to_entries
    | map(.value)
    | { under: .[0], many: .[1:] }
    | [recurse({ under: .many[0], many: .many[1:] }; .under != null)]
    | map(.under.visible_area = visible_area([.under.frame + {title: .under.title}]; .many|map(.frame)))
    | map(.under)
    | map(.percentage_visible = (.visible_area / (.frame|.w*.h)))
    | map(select(.percentage_visible > 0.01))
    | (first(.[] | select(."has-focus")) // .[-1]) as {$id, $title, frame: $zero}
    | ($zero |
        if $dir == "east" then {x: (.x + .w), y: (.y/2 + .h/2)}
        elif $dir == "west" then {x: .x, y: (.y/2 + .h/2)}
        elif $dir == "south" then {x: (.x/2 + .w/2), y: (.y + .h)}
        elif $dir == "north" then {x: (.x/2 + .w/2), y: .y}
        end | . + {w: $zero.w, h: $zero.h}) as $zero
    | sort_by(
        if $dir == "east" then [.frame.x + .frame.w, .id]
        elif $dir == "west" then [-.frame.x, -.id]
        elif $dir == "south" then [.frame.y + .frame.h, .id]
        elif $dir == "north" then [-.frame.y, -.id]
        end
    )
    | .[(map(.id) | index($id))+1:]
    | (if ($dir == "east" or $dir == "west") then [2, 1]
    elif ($dir == "north" or $dir == "south") then [1, 2]
    end) as [$x_exp, $y_exp]
    | map(.ref = {

    })
    | map(
    .distance =
        if $dir == "east" then ([.frame.x + .frame.w, .frame.x]|map(.-$zero.x|select(.>0))|min) + ([.frame.y/2 + .frame.h/2 - $zero.y -$zero.h/2, 0]|max)
        elif $dir == "west" then ([.frame.x + .frame.w, .frame.x]|map($zero.x-.|select(.>0))|min) + ([.frame.y/2 + .frame.h/2 - $zero.y - $zero.h/2, 0]|max)
        elif $dir == "south" then ([.frame.x/2 + .frame.w/2 - $zero.x - $zero.w/2, 0]|max) + ([.frame.y + .frame.h, .frame.y]|map(.-$zero.y|select(.>0))|min)
        elif $dir == "north" then ([.frame.x/2 + .frame.w/2 - $zero.x - $zero.w/2, 0]|max) + ([.frame.y + .frame.h, .frame.y]|map($zero.y-.|select(.>0))|min)
        end
    | .x_distance =
        if $dir == "east" then pow([.frame.x + .frame.w, .frame.x]|map(.-$zero.x|select(.>0))|min; 1)
        elif $dir == "west" then pow([.frame.x + .frame.w, .frame.x]|map($zero.x-.|select(.>0))|min; 1)
        elif $dir == "south" then pow(.frame.x/2 + .frame.h/2 - $zero.x; 2)
        elif $dir == "north" then pow(.frame.y/2 + .frame.w/2 - $zero.y; 2)
        end
    |.y_distance =
        if $dir == "east" then pow(.frame.y/2 + .frame.h/2 - $zero.y; 2)
        elif $dir == "west" then pow(.frame.y/2 + .frame.h/2 - $zero.y; 2)
        elif $dir == "south" then pow([.frame.y + .frame.h, .frame.y]|map(.-$zero.y|select(.>0))|min; 1)
        elif $dir == "north" then pow([.frame.y + .frame.h, .frame.y]|map($zero.y-.|select(.>0))|min; 1)
        end
    )
    | sort_by([.distance, -.z_index])
    | map(.zero = $zero)
    | map(debug(. | {title, zero, distance, frame, x_distance, y_distance, z_index}))
    | first.id')
    yabai -m window "$winid" --focus \
    || return 1
}

_focus_space() {
    local space="$1"; shift

    if _contains "$space" "next" "prev" "recent"; then
        space=$(yabai -m query --spaces --space "$space" | jq .index)
    fi

    local json
    json=$(jq -nc --argjson spc "$space" '{"BTTPredefinedActionType":(206 + $spc)}')
    json=$(echo -n "$json" | jq -Rr @uri)
    curl -G "$btt_url" -d "json=$json"
}

_move_window_to_space() {
    local space="$1"; shift

    if _contains "$space" "next" "prev" "recent"; then
        space=$(yabai -m query --spaces --space "$space" | jq .index)
    fi

    local json
    json=$(jq -nc --argjson spc "$space" '{"BTTPredefinedActionType":(215 + $spc + if $spc >= 6 then 1 else 0 end)}')
    json=$(echo -n "$json" | jq -Rr @uri)

    curl -G "$btt_url" -d "json=$json"
}

_focus_window_in_stack() {
    local stack="$1"; shift

    if ! yabai -m query --windows --window | jq -e '.id' > /dev/null; then
        _focus_topmost
        return
    fi

    if _contains "$stack" "next" "prev" "recent" "first" "last"; then
        stack=$(yabai -m query --windows --window "stack.$stack" | jq -e '."stack-index"')
    fi

    if [[ -z "$stack" ]] || ! [[ "$stack" -gt 0 ]] 2>/dev/null; then
        return 1
    fi

    local last
    last=$(yabai -m query --windows --window "stack.last" | jq -e '."stack-index"')
    yabai -m window --focus "stack.$stack"
    display-message "Stack $stack / $last"
}

_focus_window_in_space() {
    local floating_only=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --floating-only) floating_only="true"; shift ;;
            --) shift; break ;;
            *) break ;;
        esac
    done

    local window="$1"; shift

    if ! yabai -m query --windows --window | jq -e '.id' > /dev/null; then
        _focus_topmost
        return
    fi

    if ! _contains "$window" "next" "prev" "first" "last"; then
        echo "Invalid argument: $window" >&2
        return 1
    fi

    local floating_only_json is_layout_float window_pos total
    floating_only_json=$([[ -n "$floating_only" ]] && echo "true" || echo "false")
    is_layout_float=$(_is_space_float_layout && echo true || echo false)

    local result
    result=$(yabai -m query --windows --space | jq -er --arg window "$window" --argjson floating_only "$floating_only_json" --argjson is_layout_float "$is_layout_float" '.
    | map(select(."is-visible" and (."is-sticky"|not) and (if $is_layout_float then true elif $floating_only then ."split-type" == "none" and ."is-floating" else true end)))
        | (first(.[] | select(."has-focus")) // .[0]).id as $focus
        | sort_by([
            # Floating windows appear last
            if ."split-type" == "none" and ."is-floating" then 2
            else 1 end,
            .frame.x,
            .frame.y,
            ."stack-index",
            .id
        ])
        | (map(.id) | index($focus)) as $pos
        | ({first: 0, last: (length - 1), prev: ([0, $pos - 1]|max), next: ([length - 1, $pos + 1]|min)}[$window]) as $window_pos
        | "\(.[$window_pos].id):\($window_pos+1):\(length)" ')

    IFS=: read -r window window_pos total <<< "$result"

    yabai -m window --focus "$window"

    if [[ -n "$floating_only" ]]; then
        display-message "Floating $window_pos / $total"
    else
        display-message "Windows $window_pos / $total"
    fi
}

_focus_floating_window_in_space() {
    local window="$1"; shift

    if ! _contains "$window" "next" "prev" "first" "last"; then
        echo "Invalid argument: $window" >&2
        return 1
    fi

    local result
    result=$(yabai -m query --windows --space | jq -er --arg window "$window" '.
        | map(select(."is-visible" and (."is-sticky"|not) and ."split-type" == "none" and ."is-floating"))
        | (first(.[] | select(."has-focus")) // .[0]).id as $focus
        | sort_by([.frame.x, .frame.y, .id])
        | (map(.id) | index($focus)) as $pos
        | ({first: 0, last: (length - 1), prev: ([0, $pos - 1]|max), next: ([length - 1, $pos + 1]|min)}[$window]) as $window_pos
        | "\(.[$window_pos].id):\($window_pos+1):\(length)" ')

    local window_id window_pos total
    IFS=: read -r window_id window_pos total <<< "$result"

    yabai -m window --focus "$window_id"
    display-message "Windows $window_pos / $total"
}

_focus_floating_window() {
    local direction="$1"; shift

    case "$direction" in
        next|prev|first|last)
            _focus_floating_window_in_space "$direction"
            ;;
        east|west|north|south)
            yabai -m window --focus "$direction" \
            || return 1
            ;;
        *)
            echo "Invalid argument: $direction" >&2
            return 1
            ;;
    esac
}

_move_window_in_stack() {
    local stack="$1"; shift

    if _contains "$stack" "next" "prev" "recent" "first" "last"; then
        stack=$(yabai -m query --windows --window "stack.$stack" | jq -e '."stack-index"')
    fi

    if [[ -z "$stack" ]] || ! [[ "$stack" -gt 0 ]] 2>/dev/null; then
        return
    fi

    local last
    last=$(yabai -m query --windows --window "stack.last" | jq -e '."stack-index"')
    yabai -m window --swap "stack.$stack"
    yabai -m window --focus "stack.$stack"
    display-message "Stack $stack / $last"
}

_focus_display_with_fallback() {
    local display="$1"; shift
    local fallback

    if [[ "$display" == "north" || "$display" == "west" ]]; then
        fallback=prev
    else
        fallback=next
    fi

    yabai -m display --focus "$display" || yabai -m display --focus "$fallback"
}

_smart_move_window_to_next_display() {
    local win json
    win=$(yabai -m query --windows --window | jq '.id')
    json='{"BTTPredefinedActionType" : 98}'
    json=$(echo -n "$json" | jq -Rr @uri)

    if _is_window_floating; then
        curl -G "$btt_url" -d "json=$json"
        yabai -m window --focus "$win"
    else
        yabai -m window "$win" --toggle float
        yabai -m window --focus "$win"
        curl -G "$btt_url" -d "json=$json"
        yabai -m window "$win" --toggle float
    fi
}

_stack_or_warp_window() {
    local direction="$1"; shift

    if yabai -m query --windows --window | jq -e '."stack-index" > 0'; then
        yabai -m window --warp "$direction"
    else
        yabai -m window --stack "$direction"
    fi
}

_stack_windows_in_space() {
    local query='.
        | map(select(."is-visible" and (."is-sticky"|not)))
        | (first(.[] | select(."has-focus")) // .[0]) as $focus
        | [$focus.id] + map(select($focus.id != .id) | .id)
        | .[]'
    local windows=()
    while IFS= read -r w; do
        windows+=("$w")
    done < <(yabai -m query --windows --space | jq -er "$query")

    local current="${windows[0]}"
    local stack_args=()
    for w in "${windows[@]:1}"; do
        stack_args+=(--stack "$w")
    done
    yabai -m window "$current" "${stack_args[@]}"

    # Hack: When using two monitors, some windows down in the tree get "pushed"
    # to the other monitor and might not be properly captured by the query command,
    # so we need to do a second passing
    local second_passing=()
    while IFS= read -r w; do
        second_passing+=("$w")
    done < <(yabai -m query --windows --space | jq -er "$query")

    for window in "${second_passing[@]}"; do
        if ! _contains "$window" "${windows[@]}"; then
            yabai -m window "$current" --stack "$window"
        fi
    done

    display-message "${#second_passing[@]} windows stacked"
}

_stack_after_nth_window() {
    local nth="$1"; shift

    local windows=()
    while IFS= read -r w; do
        windows+=("$w")
    done < <(yabai -m query --windows --space | jq -er --argjson nth "$nth" '.
        | map(select(."is-visible" and (."is-sticky"|not)))
        | .[$nth-1:]
        | .[].id')

    local nth_window="${windows[0]}"
    local stack_args=()
    for w in "${windows[@]:1}"; do
        stack_args+=(--stack "$w")
    done
    yabai -m window "$nth_window" "${stack_args[@]}"
    display-message "${#windows[@]} windows stacked"
}

_minimize_after_nth_window() {
    local nth="$1"; shift

    local windows=()
    while IFS= read -r w; do
        windows+=("$w")
    done < <(yabai -m query --windows --space | jq -er --argjson nth "$nth" '.
        | map(select(."is-visible" and (."is-sticky"|not)))
        | .[$nth:]
        | .[].id')

    for window in "${windows[@]}"; do
        yabai -m window "$window" --minimize
    done

    display-message "${#windows[@]} windows minimized"
}

_minimize() {
    local window="$1"; shift
    yabai -m window $window --minimize
    _focus_topmost
}

_focus_topmost() {
    yabai -m window --focus "$(yabai -m query --windows --space | jq 'first(.[] | select(."is-visible" and (."is-sticky"|not))).id')"
}

_deminimize_last() {
    local window
    window=$(yabai -m query --windows | jq 'map(select(."is-minimized")) | first | .id')
    yabai -m window --deminimize "$window"
    yabai -m window --focus "$window"
}

_deminimize_all() {
    local minimized=()
    while IFS= read -r w; do
        minimized+=("$w")
    done < <(yabai -m query --windows | jq -er 'map(select(."is-minimized")) | .[].id')

    for window in "${minimized[@]}"; do
        yabai -m window --deminimize "$window"
    done
}

_hide_after_nth_window() {
    local nth="$1"; shift

    local apps=()
    while IFS= read -r a; do
        apps+=("$a")
    done < <(yabai -m query --windows --space | jq -er --argjson nth "$nth" '.
        | map(select(."is-visible" and (."is-sticky"|not)))
        | (.[:$nth-1] | map(.app) | unique) as $seen_apps
        | .[$nth:]
        | map(.app) - $seen_apps
        | .[]')

    for app in "${apps[@]}"; do
        osascript -e "tell application \"System Events\" to set visible of process \"$app\" to false"
    done

    display-message "${#apps[@]} apps hidden"
}

_unstack_window() {
    local direction="$1"; shift
    yabai -m window --insert "$direction" --toggle float --toggle float
}

_arrange_spaces() {
    local flag_apps=() flag_windows=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -a|--app) flag_apps+=("$2"); shift 2 ;;
            --app=*) flag_apps+=("${1#--app=}"); shift ;;
            -w|--window) flag_windows+=("$2"); shift 2 ;;
            --window=*) flag_windows+=("${1#--window=}"); shift ;;
            --) shift; break ;;
            *) break ;;
        esac
    done

    local specs=()
    local lines=()

    for app_spec in "${flag_apps[@]}"; do
        lines+=("app:$app_spec")
    done
    for win_spec in "${flag_windows[@]}"; do
        lines+=("title:$win_spec")
    done

    for line in "${lines[@]}"; do
        IFS=: read -r format space filter <<< "$line"

        while IFS=: read -r window _rest; do
            specs+=("$space:$window")
        done < <(yabai -m query --windows | jq -er --arg format "$format" --argjson space "$space" '.[] | select(.space != $space) | "\(.id):\(.[$format]):"' | grep -E ":$filter:")
    done

    for line in "${specs[@]}"; do
        IFS=: read -r space window <<< "$line"
        yabai -m window "$window" --focus
        sleep 0.5
        _move_window_to_space "$space"
    done
}

_get_pin_json() {
    yabai-harpoon get-focused-pin-json
}

_pin_object() {
    local position="$1"; shift

    local json type
    json=$(yabai-harpoon get-focused-pin-json)
    type=$(jq -n --argjson json "$json" '.type')

    mkdir -p "/tmp/yabai-preset/pins/"
    echo "$json" > "/tmp/yabai-preset/pins/$position.json"
    display-message "Pin $type $position"
}

_focus_pinned_object() {
    local position="$1"; shift
    yabai-harpoon focus-pin-json < "/tmp/yabai-preset/pins/$position.json"
}

_focus_pin_json() {
    echo "deprecated - use yabai-harpoon get-pin-json" >&2
    yabai-harpoon focus-pin-json
}

_is_window_floating() {
    local window="$1"

    local space is_floating
    { read -r space; read -r is_floating; } < <(yabai -m query --windows --window "$window" \
        | jq -r '.space, ."is-floating"')

    if yabai -m query --spaces --space "$space" | jq -e '.type == "float"' >/dev/null; then
        return 0
    fi

    [[ "$is_floating" == "true" ]] || return 1
}

_is_space_float_layout() {
    local space="$1"
    yabai -m query --spaces --space "$space" | jq -e '.type == "float"' >/dev/null \
    || return 1
}

_is_window_fullscreen() {
    local window="$1"

    if [[ -z "$window" ]]; then
        window=$(yabai -m query --windows | jq -r 'first(.[] | select(."has-focus")) | .id')
    fi

    local w h display display_w display_h
    { read -r w; read -r h; read -r display; } < <(yabai -m query --windows --window "$window" | jq -r '.frame.w, .frame.h, .display')
    { read -r display_w; read -r display_h; } < <(yabai -m query --displays --display "$display" | jq -r '.frame | .w, .h')

    [[ $(( 9 * ${display_w%.*} / 10 )) -le "${w%.*}" && $(( 9 * ${display_h%.*} / 10 )) -le "${h%.*}" ]] || return 1
}

_toggle_window_zoom_or_fullscreen() {
    local window="$1"

    if [[ -z "$window" ]]; then
        window=$(yabai -m query --windows | jq -r 'first(.[] | select(."has-focus")) | .id')
    fi

    if _is_window_floating "$window"; then
        if _is_window_fullscreen "$window"; then
            _restore_window_position
        else
            _store_window_position
            yabai -m window "$window" --grid "1:1:0:0:1:1"
        fi
    else
        yabai -m window "$window" --toggle zoom-fullscreen
    fi
}

_toggle_monocle_mode() {
    local fullscreen
    if yabai -m query --windows --window | jq -re '."has-fullscreen-zoom"' > /dev/null; then
        display-message "Exit Monocle"
        fullscreen=true
    else
        display-message "Enter Monocle"
        fullscreen=false
    fi

    local windows=()
    while IFS= read -r w; do
        windows+=("$w")
    done < <(yabai -m query --windows --space | jq -re --argjson fullscreen "$fullscreen" '
        .[]
        | debug($fullscreen)
        | select(
            ."is-visible"
            and (."is-sticky" | not)
            and (."stack-index" <= 1)
            and (."has-fullscreen-zoom" == $fullscreen))
        | .id')

    for window in "${windows[@]}"; do
        echo window "$window"
        yabai -m window "$window" --toggle zoom-fullscreen
    done
}

_smart_toggle_fullscreen() {
    if _is_window_floating; then
        _toggle_window_zoom_or_fullscreen
    else
        _toggle_monocle_mode
    fi
}

_toggle_yabai() {
    if yabai --stop-service; then
        display-message "Yabai Stopped"
    else
        if yabai --start-service; then
            display-message "Yabai Started"
        fi
    fi
}

_store_window_position() {
    local winid="$1"

    local window
    window=$(yabai -m query --windows --window "$window")

    _is_window_floating "$winid" || return 1
    _is_window_fullscreen "$winid" && return 1

    local frame
    frame=$(jq -enc --argjson window "$window" '$window | .frame')
    winid=$(jq -nr --argjson window "$window" '$window.id')

    mkdir -p "/tmp/yabai-preset/window-positions/"
    echo "$frame" > "/tmp/yabai-preset/window-positions/$winid.json"
}

_restore_window_position() {
    local winid="$1"

    winid=$(_default "$winid" "$(yabai -m query --windows --window | jq '.id')")

    local x y w h
    { read -r x; read -r y; read -r w; read -r h; } < <(jq -erc '.x, .y, .w, .h | floor' < "/tmp/yabai-preset/window-positions/$winid.json")

    if [[ $? -eq 0 ]]; then
        yabai -m window "$winid" --move "abs:$x:$y" \
        && yabai -m window "$winid" --resize "abs:$w:$h"
    fi
}

_print_window_mode() {
    local id stack_index has_zoom
    { read -r id; read -r stack_index; read -r has_zoom; } < <(yabai -m query --windows --window | jq -r '.id, ."stack-index", ."has-fullscreen-zoom"')

    if [[ -z "$id" || -z "$stack_index" ]]; then
        return
    fi

    if _is_window_floating; then
        echo "float"
    elif [[ "$stack_index" -gt 0 ]]; then
        local stack_count
        stack_count=$(yabai -m query --windows --window stack.last | jq -r '."stack-index"')
        echo "stack $stack_index/$stack_count"
    elif [[ "$has_zoom" == "true" ]]; then
        echo "zoom"
    else
        echo "tile"
    fi
}

_print_yabai_widget() {
    local spaces_count space_number space_mode
    { read -r spaces_count; read -r space_number; read -r space_mode; } < <(yabai -m query --spaces \
        | jq -r 'length, (map(select(."has-focus"))[0] | .index, .type)')

    local window_mode
    window_mode="$(_print_window_mode)"

    echo "$space_mode:$space_number/$spaces_count ($window_mode)"
}

_unstacked_swap_largest() {
    local focus_id pending_stack_id
    focus_id=$(yabai -m query --windows --window | jq -r '.id')

    if yabai -m query --windows --window | jq -e '."stack-index" > 0'; then
        pending_stack_id=$(yabai -m query --windows --window largest | jq -r '.id')
        _unstack_window east
    fi

    yabai -m window --swap largest

    if [[ -n "$pending_stack_id" ]]; then
        yabai -m window --focus "$pending_stack_id"
        yabai -m window west --stack "$pending_stack_id"
        yabai -m window --focus "$pending_stack_id"
        yabai -m window --focus "$focus_id"
    fi
}

_focus_pid() {
    local pid="$1"; shift

    local window
    window=$(yabai -m query --windows \
        | jq -re --argjson pid "$pid" '.
        | first(.[] | select(.pid == $pid))
        | .id
        ') \
    || return 1

    yabai -m window "$window" --focus
}

_minimize_pid() {
    local pid="$1"; shift

    local window
    window=$(yabai -m query --windows \
        | jq -re --argjson pid "$pid" '.
        | first(.[] | select(.pid == $pid))
        | .id
        ') \
    || return 1

    yabai -m window "$window" --minimize
    _focus_topmost
}

_stack_new_window() {
    local winid="$1"
    local window recent
    window=$(yabai -m query --windows --window "$window")
    recent=$(yabai -m query --windows --window recent)

    if jq -ne --argjson window "$window" '
            ($window."split-type" == "none")
            or (($window.app == "Google Chrome") and ($window.title | IN("Picture in Picture", "")))' > /dev/null; then
        return
    fi

    if [[ -n "$recent" ]] && jq -ne --argjson recent "$recent" '$recent."stack-index" > 0' > /dev/null; then
        yabai -m window "$(jq -n --argjson recent "$recent" '$recent.id')" --stack "$winid"
    fi
}

_get_window_info() {
    local windowid="$1"; shift
    yabai -m query --windows | jq -e --argjson windowid "$windowid" 'first(.[] | select(.id == $windowid))'
    return $?
}

_swap_window() {
    local direction="$1"; shift
    yabai -m window --swap "$direction" || return 1
}

_warp_window() {
    local direction="$1"; shift
    yabai -m window --warp "$direction" || _unstack_window "$direction"
}

_toggle_float() {
    yabai -m window --toggle float
    if _is_window_floating; then
        yabai -m window --grid "8:8:1:1:6:6"
        echo floating
    else
        echo tiling
    fi
}

_toggle_split() {
    yabai -m window --toggle split
}

_balance() {
    yabai -m space --balance
}

_resize() {
    local resize_type="$1"; shift
    local amount="$1"; shift

    case "$resize_type" in
        smart|width)
            yabai -m window --resize "bottom_right:$amount:0"
            ;;
        height)
            yabai -m window --resize "bottom_right:0:$amount"
            ;;
    esac
}

_focus_back_and_forth() {
    yabai -m window --focus recent
}

_restart_wm() {
    if yabai --stop-service && yabai --start-service; then
        display-message "Yabai Restarted"
    else
        if yabai --start-service; then
            display-message "Yabai Started"
        fi
    fi
}

_layout_float_all() {
    while IFS= read -r space; do
        yabai -m space "$space" --layout float
    done < <(yabai -m query --spaces | jq -r '.[].index')
    display-message "Layout float (all spaces)"
}

_get_recent_window_id() {
    yabai -m query --windows --space | jq -er '
        first(.[] | select(."is-visible" and (."is-sticky"|not) and (."has-focus"|not)))
        | .id' \
    || return 1
}

_focus_recent() {
    local recent
    recent=$(_get_recent_window_id) || return 1
    yabai -m window --focus "$recent"
}

_side_by_side() {
    local focused
    focused=$(yabai -m query --windows --window | jq -r '.id')

    # Make focused window floating if not already, then snap left
    wm-set is-window-floating || wm-set toggle-float
    _snap west

    # Switch to recent window, make floating if not already, then snap right
    _focus_recent
    wm-set is-window-floating || wm-set toggle-float
    _snap east

    # Focus back to original window
    yabai -m window --focus "$focused"
}

_snap() {
    local direction="$1"; shift

    local grid
    grid=$(( yabai -m query --windows --window; yabai -m query --displays --display ) | jq -rs --arg dir "$direction" '
        .[0].frame as $win | .[1].frame as $dsp |
        # Check if window is already on the requested side
        def on_side:
            if $dir == "west" then ($win.x - $dsp.x) < ($dsp.w * 0.05)
            elif $dir == "east" then (($dsp.x + $dsp.w) - ($win.x + $win.w)) < ($dsp.w * 0.05)
            elif $dir == "north" then ($win.y - $dsp.y) < ($dsp.h * 0.05)
            elif $dir == "south" then (($dsp.y + $dsp.h) - ($win.y + $win.h)) < ($dsp.h * 0.05)
            else false end;
        if on_side | not then "half"
        elif $dir == "west" or $dir == "east" then
            ($win.w / $dsp.w) as $ratio |
            if ($ratio - 0.5 | fabs) < 0.05 then "two_thirds"
            elif ($ratio - 0.6667 | fabs) < 0.05 then "one_third"
            else "half"
            end
        else
            ($win.h / $dsp.h) as $ratio |
            if ($ratio - 0.5 | fabs) < 0.05 then "two_thirds"
            elif ($ratio - 0.6667 | fabs) < 0.05 then "one_third"
            else "half"
            end
        end')

    case "$direction:$grid" in
        west:half)          yabai -m window --grid 1:2:0:0:1:1 ;;
        west:two_thirds)    yabai -m window --grid 1:3:0:0:2:1 ;;
        west:one_third)     yabai -m window --grid 1:3:0:0:1:1 ;;
        east:half)          yabai -m window --grid 1:2:1:0:1:1 ;;
        east:two_thirds)    yabai -m window --grid 1:3:1:0:2:1 ;;
        east:one_third)     yabai -m window --grid 1:3:2:0:1:1 ;;
        north:half)         yabai -m window --grid 2:1:0:0:1:1 ;;
        north:two_thirds)   yabai -m window --grid 3:1:0:0:1:2 ;;
        north:one_third)    yabai -m window --grid 3:1:0:0:1:1 ;;
        south:half)         yabai -m window --grid 2:1:0:1:1:1 ;;
        south:two_thirds)   yabai -m window --grid 3:1:0:1:1:2 ;;
        south:one_third)    yabai -m window --grid 3:1:0:2:1:1 ;;
        *)
            echo "Invalid argument: $direction" >&2
            return 1
            ;;
    esac
}

_get_app_window_id() {
    local match_title=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --match-title) match_title="$2"; shift 2 ;;
            --match-title=*) match_title="${1#--match-title=}"; shift ;;
            --) shift; break ;;
            *) break ;;
        esac
    done

    local app_name="$1"; shift

    # Accept path or name
    if [[ "$app_name" == *.app ]]; then
        app_name=$(basename "$app_name" .app)
    fi

    local title_filter='true'
    local jq_title_args=()
    if [[ -n "$match_title" ]]; then
        title_filter='(.title | test($title_re))'
        jq_title_args=(--arg title_re "$match_title")
    fi

    local current_space
    current_space=$(yabai -m query --spaces --space | jq '.index')

    # Find best window: prefer non-minimized, prefer current space
    yabai -m query --windows \
    | jq -re "${jq_title_args[@]}" --arg app "$app_name" --argjson cs "$current_space" '
        [.[] | select(.app == $app) | select('"$title_filter"')]
        | if length == 0 then error("no windows") else . end
        | sort_by([
            (if ."is-minimized" then 1 else 0 end),
            (if .space == $cs then 0 else 1 end)
        ])
        | first
        | .id
    '
}

_focus_app() {
    local match_title=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --match-title) match_title="$2"; shift 2 ;;
            --match-title=*) match_title="${1#--match-title=}"; shift ;;
            --) shift; break ;;
            *) break ;;
        esac
    done

    local app_name="$1"; shift

    local match_title_args=()
    if [[ -n "$match_title" ]]; then
        match_title_args=(--match-title "$match_title")
    fi

    local window
    if ! window=$(_get_app_window_id "${match_title_args[@]}" "$app_name"); then
        open -a "$app_name"
        return
    fi

    local current_space target_space is_minimized
    current_space=$(yabai -m query --spaces --space | jq '.index')

    IFS=: read -r target_space is_minimized < <(yabai -m query --windows --window "$window" \
        | jq -re '"\(.space):\(."is-minimized")"')

    if [[ "$is_minimized" == "true" ]]; then
        yabai -m window "$window" --deminimize
    fi

    if [[ "$target_space" != "$current_space" ]]; then
        _focus_space "$target_space"
    fi

    yabai -m window "$window" --focus
}

preset="$1"; shift
case "$preset" in
    focus-window-id) _focus_window_id "$@" ;;
    focus-window) _focus_window "$@" ;;
    focus-space) _focus_space "$@" ;;
    move-window-to-space) _move_window_to_space "$@" ;;
    focus-window-in-stack) _focus_window_in_stack "$@" ;;
    focus-window-in-space) _focus_window_in_space "$@" ;;
    focus-floating-window-in-space) _focus_floating_window_in_space "$@" ;;
    focus-floating-window) _focus_floating_window "$@" ;;
    move-window-in-stack) _move_window_in_stack "$@" ;;
    focus-display-with-fallback) _focus_display_with_fallback "$@" ;;
    smart-move-window-to-next-display) _smart_move_window_to_next_display ;;
    stack-or-warp-window) _stack_or_warp_window "$@" ;;
    stack-windows-in-space) _stack_windows_in_space ;;
    stack-after-nth-window) _stack_after_nth_window "$@" ;;
    minimize-after-nth-window) _minimize_after_nth_window "$@" ;;
    minimize) _minimize "$@" ;;
    focus-topmost) _focus_topmost ;;
    deminimize-last) _deminimize_last ;;
    deminimize-all) _deminimize_all ;;
    hide-after-nth-window) _hide_after_nth_window "$@" ;;
    unstack-window) _unstack_window "$@" ;;
    arrange-spaces) _arrange_spaces "$@" ;;
    get-pin-json) _get_pin_json ;;
    pin-object) _pin_object "$@" ;;
    focus-pinned-object) _focus_pinned_object "$@" ;;
    focus-pin-json) _focus_pin_json ;;
    is-window-floating) _is_window_floating "$@" ;;
    is-space-float-layout) _is_space_float_layout "$@" ;;
    is-window-fullscreen) _is_window_fullscreen "$@" ;;
    toggle-window-zoom-or-fullscreen) _toggle_window_zoom_or_fullscreen "$@" ;;
    toggle-monocle-mode) _toggle_monocle_mode ;;
    smart-toggle-fullscreen) _smart_toggle_fullscreen ;;
    toggle-yabai) _toggle_yabai ;;
    store-window-position) _store_window_position "$@" ;;
    restore-window-position) _restore_window_position "$@" ;;
    print-window-mode) _print_window_mode ;;
    print-yabai-widget) _print_yabai_widget ;;
    unstacked-swap-largest) _unstacked_swap_largest ;;
    focus-pid) _focus_pid "$@" ;;
    minimize-pid) _minimize_pid "$@" ;;
    stack-new-window) _stack_new_window "$@" ;;
    get-window-info) _get_window_info "$@" ;;
    swap-window) _swap_window "$@" ;;
    warp-window) _warp_window "$@" ;;
    toggle-float) _toggle_float ;;
    toggle-split) _toggle_split ;;
    balance) _balance ;;
    resize) _resize "$@" ;;
    focus-back-and-forth) _focus_back_and_forth ;;
    restart-wm) _restart_wm ;;
    toggle-wm) _toggle_yabai ;;
    print-wm-widget) _print_yabai_widget ;;
    layout-stack) yabai -m space --layout stack; display-message "Layout stack" ;;
    layout-bsp) yabai -m space --layout bsp; display-message "Layout bsp" ;;
    layout-float) yabai -m space --layout float; display-message "Layout float" ;;
    layout-float-all) _layout_float_all ;;
    flatten) display-message "Not supported in yabai" ;;
    insert-direction) yabai -m window --insert "$1" ;;
    mirror) yabai -m space --mirror "$1" ;;
    rotate) yabai -m space --rotate "$1" ;;
    get-recent-window-id) _get_recent_window_id ;;
    focus-recent) _focus_recent ;;
    side-by-side) _side_by_side ;;
    snap) _snap "$@" ;;
    get-app-window-id) _get_app_window_id "$@" ;;
    focus-app) _focus_app "$@" ;;
    *) echo "command not found - $preset" >&2; exit 1 ;;
esac
