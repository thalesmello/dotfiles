#!/usr/bin/env -S fish --no-config
set -x PATH /opt/homebrew/bin (status dirname) $PATH

function iterm-preset
    set preset $argv[1]
    set -e argv[1]

    switch "$preset"
    case "new-window"
        osascript -e 'tell application "iTerm2" to create window with default profile'
    case "is-floating-window-active"
        test "$(hs -c 'if require("preset").isFloatingTerminalActive() then print("yes") end')" = "yes"
    case "hide-floating-terminal"
        iterm-preset is-floating-window-active
        and osascript -e '
            tell application "iTerm2"
                hide hotkey window current window
            end tell
        '
    case "reveal-hotkey-window"
        # A hidden hotkey window is not exposed to AppleScript at all, so it
        # can't be revealed via `reveal hotkey window`. Instead synthesize the
        # profile's global hotkey (Ctrl+Opt+Cmd+/), which iTerm2 catches
        # system-wide. Guard on the window already being active so this only
        # ever reveals.
        iterm-preset is-floating-window-active
        or osascript-preset send-keys ctrl alt cmd slash
    case "new-split"
        argparse 'v/vertical' 'h/horizontal' 'c/cmd=' -- $argv
        or return 1

        if set -q _flag_vertical
            set direction "vertically"
        else
            set direction "horizontally"
        end

        if set -q _flag_cmd
            set _flag_cmd "$_flag_cmd; or read -P 'Press Enter to close'"
            set escaped_cmd (string replace -a '\\' '\\\\' -- $_flag_cmd | string replace -a '$' '\\\\$' | string replace -a '"' '\\\\\\"')
            osascript -e '
                tell application "iTerm"
                    set oldIds to unique ID of every session of current tab of current window
                    try
                        tell current session of current window to tell (split '"$direction"' with default profile) to write text "exec fish -c \"'"$escaped_cmd"'\""
                    on error
                        set newIds to unique ID of every session of current tab of current window
                        repeat with newId in newIds
                            if newId is not in oldIds then
                                repeat with s in every session of current tab of current window
                                    if unique ID of s is (newId as text) then
                                        tell s to write text "exec fish -c \"'"$escaped_cmd"'\""
                                        exit repeat
                                    end if
                                end repeat
                                exit repeat
                            end if
                        end repeat
                    end try
                end tell
            '
        else
            osascript -e "tell application \"iTerm\" to tell current session of current window to split $direction with default profile"
        end
    case "nvim-tab-remote"
        function __exit_on_error -a message
            echo "Error: $message" >&2
            exit 1
        end

        if set -q NVIM
            nvim --server "$NVIM" $argv
            or __exit_on_error "nvim --server exited with an error"
            return
        end

        set -l servers (nvim --headless -c 'lua for _, s in ipairs(vim.fn.serverlist({peer=true})) do print(s) end' -c 'qa!' 2>&1)
        or __exit_on_error "failed to list nvim servers"

        if test -n "$TMUX"
            set tab_ttys (tmux list-panes -F '#{pane_tty}')
            or __exit_on_error "failed to get tab ttys"
        else
            set -l raw_ttys (osascript -e 'tell application "iTerm" to get tty of every session of current tab of current window')
            or __exit_on_error "failed to get tab ttys"
            # Note: `string trim` exits 1 when it trims nothing, so keep it out
            # of the status check above.
            set tab_ttys (string split ", " -- $raw_ttys | string trim)
        end

        set -l found_server
        for server in $servers
            set -l nvim_pid (string match -r 'nvim\.(\d+)\.' "$server")[2]
            if test -n "$nvim_pid"
                if test -d /proc/$nvim_pid/fd
                    set nvim_tty (readlink /proc/$nvim_pid/fd/0 2>/dev/null)
                else
                    set nvim_tty (lsof -p "$nvim_pid" 2>/dev/null | string match -r '/dev/ttys\d+' | head -1)
                end
                if contains -- "$nvim_tty" $tab_ttys
                    set found_server "$server"
                    break
                end
            end
        end

        if test -n "$found_server"
            nvim --server "$found_server" $argv
        else
            nvim $argv
        end
        or __exit_on_error "nvim exited with an error"

    case "nvim-open-in-tab"
        set -l file (realpath "$(eval echo $argv[1])" 2>/dev/null)
        or begin
            echo "Error: file not found: $argv[1]" >&2
            exit 1
        end

        iterm-preset nvim-tab-remote --remote "$file"

    case "focus-pane-with-fallback"
        set direction $argv[1]

        switch "$direction"
        case "left"
            set key_code 123
            set fallback_key "h"
        case "right"
            set key_code 124
            set fallback_key "l"
        case "down"
            set key_code 125
            set fallback_key "j"
        case "up"
            set key_code 126
            set fallback_key "k"
        case "*"
            return 1
        end

        echo (osascript -e 'tell application "iTerm2" to get ((count of sessions of current tab of current window) as text) & " " & (id of current session of current window)') | read session_count old_session

        if test "$session_count" -le 1
            osascript-preset send-keys ctrl alt $fallback_key
        else

            osascript-preset send-keys cmd alt $direction

            set new_session (osascript -e 'tell application "iTerm2" to get id of current session of current window')

            if test "$old_session" = "$new_session"
                osascript-preset send-keys ctrl alt $fallback_key
            end
        end
    case "iterate-windows"
        # Cycle iTerm windows, skipping the devserver window. When iTerm is
        # already frontmost, advance to the next eligible window (wrapping);
        # otherwise bring the most recently used eligible window forward.
        # Windows are ordered by id (like chrome-preset cycle-profile-windows)
        # so repeated presses cycle predictably.
        #
        # Everything runs in ONE osascript call: querying, the cycle math, and
        # the focus. Splitting it across multiple osascript invocations (and a
        # System Events frontmost lookup) added several slow Apple-event
        # round-trips per press.
        argparse 'except-window-id=' 'prev' -- $argv
        or return 1

        set -l except_id ""
        set -q _flag_except_window_id; and set except_id "$_flag_except_window_id"

        set -l want_prev 0
        set -q _flag_prev; and set want_prev 1

        osascript -e '
            on run argv
                set exceptId to item 1 of argv
                set wantPrev to (item 2 of argv) is "1"
                tell application "iTerm"
                    -- Eligible window ids (devserver excluded).
                    set ids to {}
                    repeat with w in windows
                        set wid to id of w
                        if (wid as text) is not exceptId then set end of ids to wid
                    end repeat
                    if (count of ids) is 0 then
                        activate
                        return
                    end if
                    -- iTerm lists windows front-to-back, so the first eligible
                    -- id is the most recently used non-devserver window.
                    set recentId to item 1 of ids
                    -- Sort ascending for stable cycling.
                    set n to count of ids
                    repeat with i from 1 to n - 1
                        repeat with j from 1 to (n - i)
                            if (item j of ids) > (item (j + 1) of ids) then
                                set tmp to item j of ids
                                set item j of ids to item (j + 1) of ids
                                set item (j + 1) of ids to tmp
                            end if
                        end repeat
                    end repeat
                    -- Locate the current window within the eligible list.
                    set isFront to frontmost
                    set curId to missing value
                    try
                        set curId to id of current window
                    end try
                    set pos to 0
                    repeat with i from 1 to n
                        if (item i of ids) is curId then
                            set pos to i
                            exit repeat
                        end if
                    end repeat
                    -- Already in iTerm on an eligible window: step to the next.
                    -- On the current eligible window from elsewhere: return to
                    -- it. On the devserver (or nothing): most recent eligible.
                    if isFront and pos > 0 then
                        if wantPrev then
                            set targetPos to ((pos - 2 + n) mod n) + 1
                        else
                            set targetPos to (pos mod n) + 1
                        end if
                        set targetId to item targetPos of ids
                    else if pos > 0 then
                        set targetId to item pos of ids
                    else
                        set targetId to recentId
                    end if
                    activate
                    repeat with w in windows
                        if id of w is targetId then
                            set index of w to 1
                            exit repeat
                        end if
                    end repeat
                end tell
            end run
        ' "$except_id" "$want_prev"
    case "*"
        return
    end
end

iterm-preset $argv
