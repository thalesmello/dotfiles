#!/opt/homebrew/bin/fish --no-config
set -x PATH /opt/homebrew/bin (status dirname) $PATH
set -g CHROME_PRESET_DB "$HOME/.local/share/chrome-preset/apps.db"

function app-db-init
    mkdir -p (path dirname "$CHROME_PRESET_DB")
    sqlite3 "$CHROME_PRESET_DB" "
        CREATE TABLE IF NOT EXISTS apps (
            app_name TEXT PRIMARY KEY,
            window_id TEXT NOT NULL,
            chrome_info TEXT NOT NULL
        );
    "
end

function sq-escape
    string replace -a "'" "''" $argv
end

function chrome-preset
    set preset $argv[1]
    set -e argv[1]

    switch "$preset"
    case "focus-tab"
        # Activate a Chrome tab and bring its window to front in a single
        # osascript call. Returns non-zero if the tab/window wasn't found
        # (e.g. tab was closed), which callers use to trigger pin refresh.
        set tab_id $argv[1]
        set -e argv[1]
        set chrome_window_id $argv[1]
        set -e argv[1]

        set result (osascript -l JavaScript -e "
            const chrome = Application('Google Chrome');
            const wins = chrome.windows();
            let found = false;
            for (const w of wins) {
                if (w.id() == $chrome_window_id) {
                    const tabs = w.tabs();
                    for (let i = 0; i < tabs.length; i++) {
                        if (tabs[i].id() == $tab_id) {
                            w.activeTabIndex = i + 1;
                            w.index = 1;
                            chrome.activate();
                            found = true;
                            break;
                        }
                    }
                    break;
                }
            }
            found ? 'ok' : 'not_found';
        ")

        test "$result" = "ok"
        or return 1

    case "focus-window"
        set window_id $argv[1]
        set -e argv[1]

        osascript -e "tell application \"Google Chrome\"
            set index of (first window whose id is $window_id) to 1
            activate
        end tell"
        or return 1
    case "focus-url"
        set regex $argv[1]
        set -e argv[1]

        env OUTPUT_FORMAT=json chrome-cli list links \
        | jq -er --arg regex "$regex" '
        first(.tabs.[] | select(.url | test($regex)))
        | "\(.windowId):\(.id)"' \
        | read -d: -l chrome_window_id tab_id

        chrome-preset focus-window "$chrome_window_id"
        and chrome-cli activate -t "$tab_id"

        or return 1
    case "check-url"
        set regex $argv[1]
        set -e argv[1]

        set json (env OUTPUT_FORMAT=json chrome-cli list links | string collect)
        jq -ern --arg regex "$regex" --argjson json "$json" '
        $json
        | first(.tabs.[] | select(.url | test($regex)))
        | .id'
        or return 1

    case "focus-or-open-url"
        argparse fallback= profile= label= -- $argv
        or return 1

        set regex $argv[1]
        set -e argv[1]

        if test -n "$_flag_fallback"
            set url "$_flag_fallback"
        else
            set url "$regex"
            set regex (string escape --style=regex "$regex")
        end

        if test -n "$_flag_label"
            display-message "Open $_flag_label"
        end

        chrome-preset focus-url "$regex"
        or chrome-preset open-url --newtab --profile="$_flag_profile" "$url"
        or return 1
    case "check-or-open-url"
        argparse fallback= profile= label= -- $argv
        or return 1

        set regex $argv[1]
        set -e argv[1]

        if test -n "$_flag_fallback"
            set url "$_flag_fallback"
        else
            set url "$regex"
            set regex (string escape --style=regex "$regex")
        end

        if test -n "$_flag_label"
            display-message "Check $_flag_label"
        end

        chrome-preset check-url "$regex"
        or chrome-preset open-url --newtab --profile="$_flag_profile" "$url"
        or return 1
    case "check-tab-id"
        set tab_id $argv[1]
        set -e argv[1]

        set json (env OUTPUT_FORMAT=json chrome-cli info -t "$tab_id" | string collect)

        test -z "$json"; and return 1

        echo "$json"

    case "get-window-title"
        osascript -e '
            tell application "Google Chrome"
                return properties of front window
            end tell
        '

    case "get-profile-name"
        set profile $argv[1]
        set -e argv[1]

        jq --arg profile "$profile" -r '.profile.info_cache[$profile] | "\(.gaia_given_name) (\((.enterprise_label | select(. != "")) // .name))"' <"$HOME/Library/Application Support/Google/Chrome/Local State"

    case focus-profile
        set profile $argv[1]
        set -e argv[1]

        set profile_name (chrome-preset get-profile-name "$profile")
        and osascript-preset show-or-hide-app --only-show "Google Chrome"
        and osascript-preset trigger-menu-bar --app "Google Chrome" "Profiles;$profile_name"

    case "open-url"
        argparse profile= label= newtab newtabright -- $argv
        or return 1

        set url $argv[1]
        set -e argv[1]

        if test -n "$_flag_label"
            display-message "Open $_flag_label"
        end

        if not string match -qr '^https?://' "$url"
            set url "https://$url"
        end

        set app (hs-preset get-active-app)

        if test "$app" != "Google Chrome"; or set -q _flag_newtab
            set extra_args

            if test -n "$_flag_profile"
                set -a extra_args "--profile-directory=$_flag_profile"
            end

            open -n -a "Google Chrome" --args "$url" $extra_args
        else if set -q _flag_newtabright
            test -n "$_flag_profile"; and chrome-preset focus-profile "$_flag_profile"

            chrome-preset new-tab --right "$url"
        else if test -z "$_flag_profile"
            env OUTPUT_FORMAT=json chrome-cli info | jq -r '.id' | read --line tab_id
            chrome-cli open "$url" $extra_args -t "$tab_id"
        else
            set profile_name (chrome-preset get-profile-name "$_flag_profile")
            osascript -e "
                tell application \"System Events\"
                    tell process \"Google Chrome\"
                        set windowTitles to name of every window
                    end tell
                end tell

                if (count of windowTitles) > 0 and item 1 of windowTitles contains \"$profile_name\" then
                    tell application \"Google Chrome\"
                        set URL of active tab of front window to \"$url\"
                    end tell
                else
                    set matchIndex to 0
                    repeat with i from 1 to count of windowTitles
                        if item i of windowTitles contains \"$profile_name\" then
                            set matchIndex to i
                            exit repeat
                        end if
                    end repeat

                    if matchIndex > 0 then
                        tell application \"Google Chrome\"
                            set targetWin to window matchIndex
                            set index of targetWin to 1
                            tell targetWin
                                make new tab with properties {URL:\"$url\"}
                            end tell
                        end tell
                    end if
                end if
            "
        end

    case "new-tab"
        argparse right -- $argv
        or return 1

        set pos ""
        if set -q _flag_right
            set pos " at after tab (active tab index)"
        end

        echo (count $argv) $argv
        set props ""
        if test (count $argv) -ge 1
            set url $argv[1]
            set -e argv[1]

            set props " with properties {URL:\"$url\"}"
        end

        set cmd "
            tell application \"Google Chrome\"
                tell front window
                    set newTab to make new tab$pos$props
                    return id of newTab
                end tell
            end tell"

        osascript -e "$cmd"

    case "close-tabs-with-url"
        set regex $argv[1]
        set -e argv[1]

        set tabs (env OUTPUT_FORMAT=json chrome-cli list links \
        | jq -er --arg regex "$regex" '
        .tabs.[]
        | select(.url | test($regex))
        | debug(.)
        | .id')
        and for tab_id in $tabs
            chrome-cli close -t "$tab_id"
        end
        or return 1

    case "click-selector"
        set selector $argv[1]
        set -e argv[1]

        chrome-cli execute "document.querySelector($(string escape "$selector")).click()"
    case "create-app"
        app-db-init
        argparse profile= -- $argv

        set appname $argv[1]
        set -e argv[1]

        set url $argv[1]
        set -e argv[1]

        yabai -m signal --add \
            event=window_created \
            app='^Google Chrome$' \
            label="store_chrome_preset_app_info" \
            action="fish -c 'chrome-preset store-preset-app --window-id \"\$YABAI_WINDOW_ID\" \"$appname\"'; yabai -m signal --remove store_chrome_preset_app_info"

        open -na 'Google Chrome' --args --profile-directory="$_flag_profile" --app="$url"

    case store-preset-app
        argparse window-id= -- $argv

        set appname $argv[1]
        set -e argv[1]

        set window_id "$_flag_window_id"

        app-db-init
        set chrome_info (env OUTPUT_FORMAT=json chrome-cli info | string collect)
        sqlite3 "$CHROME_PRESET_DB" "INSERT OR REPLACE INTO apps (app_name, window_id, chrome_info) VALUES ('$(sq-escape $appname)', '$window_id', '$(sq-escape $chrome_info)');"
    case "open-in-app"
        argparse profile= -- $argv

        set appname $argv[1]
        set -e argv[1]

        set url $argv[1]
        set -e argv[1]

        set window (sqlite3 "$CHROME_PRESET_DB" "SELECT window_id FROM apps WHERE app_name = '$(sq-escape $appname)';")

        if test -n "$window"; and yabai-preset get-window-info "$window" >/dev/null
            set chrome_info (sqlite3 "$CHROME_PRESET_DB" "SELECT chrome_info FROM apps WHERE app_name = '$(sq-escape $appname)';")

            chrome-cli open "$url" -t "$(jq -nr --argjson app "$chrome_info" '$app.id')"
            wm-preset focus-window-id "$window"
        else
            chrome-preset create-app --profile="$_flag_profile" "$appname" "$url"
        end
    case "get-app-window-id"
        set appname $argv[1]
        set -e argv[1]

        set window_id (sqlite3 "$CHROME_PRESET_DB" "SELECT window_id FROM apps WHERE app_name = '$(sq-escape $appname)';")
        test -n "$window_id"; or return 1
        echo "$window_id"
    case "focus-or-create-app"
        argparse profile= enforce-url -- $argv

        set appname $argv[1]
        set -e argv[1]

        set url $argv[1]
        set -e argv[1]

        if set window (chrome-preset get-app-window-id "$appname"); and yabai-preset get-window-info "$window" >/dev/null
            if set -q _flag_enforce_url
                set chrome_info (sqlite3 "$CHROME_PRESET_DB" "SELECT chrome_info FROM apps WHERE app_name = '$(sq-escape $appname)';")
                set tab_id (jq -nr --argjson app "$chrome_info" '$app.id')
                set current_url (env OUTPUT_FORMAT=json chrome-cli info -t "$tab_id" | jq -r '.url')
                if test "$current_url" != "$url"
                    chrome-cli open "$url" -t "$tab_id"
                end
            end

            wm-preset focus-window-id "$window"
        else
            chrome-preset create-app --profile="$_flag_profile" "$appname" "$url"
        end
    case "alternate-app"
        argparse profile= minimize=? hide=? app= -- $argv

        set app "$_flag_app"

        set fallback

        set app_window_id (sqlite3 "$CHROME_PRESET_DB" "SELECT window_id FROM apps WHERE app_name = '$(sq-escape $app)';")

        if test -n "$app_window_id"

            if set active (yabai -m query --windows --window 2>/dev/null)
                and set active_id (jq -nr --argjson active "$active" '$active.id' 2>/dev/null)
                and test "$active_id" = "$app_window_id"

                if set -q _flag_hide
                    hs-preset send-keys cmd h
                else if set -q _flag_minimize
                    yabai-preset minimize
                else
                    wm-preset focus-window-id recent
                end
            else
                set fallback 1
            end
        else
            set fallback 1
        end


        if test -n "$fallback"
            chrome-preset focus-or-create-app --profile "$_flag_profile" "$app" $argv
        end
    case "get-app-name"
        argparse window-id= -- $argv

        set appname (sqlite3 "$CHROME_PRESET_DB" "SELECT app_name FROM apps WHERE window_id = '$_flag_window_id';")
        test -n "$appname"; or return 1
        echo "$appname"
    case "focus-profile-window"
        set profile_name $argv[1]
        set -e argv[1]
        set regex (string escape --style=regex "$profile_name")

        set app_window_ids (sqlite3 "$CHROME_PRESET_DB" "SELECT window_id FROM apps;")

        set exclude_json (printf '%s\n' $app_window_ids | jq -Rn '[inputs | tonumber]')
        set windows (yabai-preset list-windows --regex "$regex" | jq -r --argjson exclude "$exclude_json" 'select(.id | IN($exclude[]) | not) | .id' | sort -n)
        or return 1

        test (count $windows) -gt 0; or return 1

        yabai-preset focus-window-id "$windows[1]"
        and osascript-preset trigger-menu-bar --app "Google Chrome" "Profiles;$profile_name"
    case "cycle-profile-windows"
        argparse 'next' 'prev' -- $argv
        or return 1

        set profile_name $argv[1]
        set -e argv[1]
        set regex (string escape --style=regex "$profile_name")

        set direction next
        if set -q _flag_prev
            set direction prev
        end

        set current_id (yabai-preset query-windows --window | jq -r '.id')
        or return 1

        set app_window_ids (sqlite3 "$CHROME_PRESET_DB" "SELECT window_id FROM apps;")

        if contains -- "$current_id" $app_window_ids
            osascript-preset trigger-menu-bar --app "Google Chrome" "Profiles;$profile_name"
            return
        end

        set exclude_json (printf '%s\n' $app_window_ids | jq -Rn '[inputs | tonumber]')
        set windows (yabai-preset list-windows --regex "$regex" | jq -r --argjson exclude "$exclude_json" 'select(.id | IN($exclude[]) | not) | .id' | sort -n)
        or return 1

        set count (count $windows)
        set pos (contains --index "$current_id" $windows)
        or return 1

        if test "$direction" = "next"
            set target_pos (math "$pos % $count + 1")
        else
            set target_pos (math "($pos - 2 + $count) % $count + 1")
        end

        yabai-preset focus-window-id "$windows[$target_pos]"
    case '*'
        return 1
    end
end

chrome-preset $argv
