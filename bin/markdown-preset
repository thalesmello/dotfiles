#!/usr/bin/env -S fish --no-config
set -x PATH /opt/homebrew/bin (status dirname) $PATH

function markdown-preset
    set preset $argv[1]
    set -e argv[1]

    switch "$preset"
    case "is-clipboard-rtf"
        set -l has_rtf (/usr/bin/osascript -l JavaScript -e '
            ObjC.import("AppKit");
            var pb = $.NSPasteboard.generalPasteboard;
            var rtfData = pb.dataForType($.NSPasteboardTypeRTF);
            (rtfData && !rtfData.isNil()) ? "yes" : "no";
        ')
        test "$has_rtf" = yes

    case "is-clipboard-md"
        set -l text (pbpaste 2>/dev/null)
        or return 1
        test -n "$text"
        or return 1
        string match -rq '(?m)^#{1,6} |(?m)^```|\*\*[^*]+\*\*|\[[^\]]+\]\([^)]+\)|(?m)^> |(?m)^[-*+] ' -- "$text"

    case "stdin-to-md"
        pandoc -f rtf -t markdown

    case "stdin-to-rtf"
        pandoc -f markdown -t rtf

    case "clipboard-to-md"
        set -l rtf (/usr/bin/osascript -l JavaScript -e '
            ObjC.import("AppKit");
            var pb = $.NSPasteboard.generalPasteboard;
            var rtfData = pb.dataForType($.NSPasteboardTypeRTF);
            if (rtfData && !rtfData.isNil()) {
                var str = $.NSString.alloc.initWithDataEncoding(rtfData, 4);
                str.js;
            }
        ')
        or return 1
        test -n "$rtf"
        or return 1
        printf '%s\n' $rtf | pandoc -f rtf -t markdown | pbcopy

    case "clipboard-to-rtf"
        set -l tmpfile (mktemp /tmp/markdown-preset.XXXXXX.rtf)
        pbpaste | pandoc -f markdown -t rtf > $tmpfile
        or begin
            rm -f $tmpfile
            return 1
        end
        /usr/bin/osascript -e "set the clipboard to (read POSIX file \"$tmpfile\" as «class RTF »)"
        rm -f $tmpfile

    case '*'
        return 1
    end
end

markdown-preset $argv
