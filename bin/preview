#!/bin/sh

# Quick Look one or more files from the command line — the same preview you get
# by highlighting a file in Finder and pressing the space bar.
#
#   preview photo.jpg                 # Quick Look a single file
#   preview page1.pdf page2.pdf       # Quick Look several files at once
#   cat image.png | preview           # Quick Look data piped on stdin

set -e

# Quick Look the given files. qlmanage -p blocks until the preview window is
# closed, but it opens the window in the background. Launch it, then bring the
# qlmanage process frontmost so the preview appears on top of other windows.
quick_look() {
    # qlmanage is chatty on stderr/stdout even on success; silence it.
    qlmanage -p "$@" >/dev/null 2>&1 &
    ql_pid=$!

    # Give the window a moment to appear, then raise qlmanage to the front.
    # Setting frontmost succeeds even before the window exists, so activate a
    # few times over a short window to reliably catch it once it's up.
    for _ in 1 2 3; do
        sleep 0.2
        osascript -e "tell application \"System Events\" to set frontmost of every process whose unix id is $ql_pid to true" >/dev/null 2>&1
    done

    wait "$ql_pid"
}

# No arguments: if something is piped in, stash it in a temp file and preview
# that; otherwise show usage.
if [ "$#" -eq 0 ]; then
    if [ -t 0 ]; then
        echo "usage: preview <filename> [filename ...]" >&2
        echo "       <command> | preview" >&2
        exit 1
    fi
    tmp=$(mktemp "${TMPDIR:-/tmp}/preview.XXXXXX")
    cat > "$tmp"
    trap 'rm -f "$tmp"' EXIT
    quick_look "$tmp"
    exit 0
fi

quick_look "$@"
