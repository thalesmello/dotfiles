#!/usr/bin/env -S fish --no-config
set -x PATH /opt/homebrew/bin (status dirname) $PATH
set DB_PATH "$HOME/.local/share/yabai-preset/window.db"

function yabai-preset
    set preset $argv[1]
    set -e argv[1]

    switch "$preset"
    case "query-windows"
        yabai -m query --windows $argv
    case "get-focused-window-id"
        yabai -m query --windows --window | jq -r '.id'
    case "get-space-window-ids"
        yabai -m query --windows --space | jq -r '.[] | select(."is-visible" and (."is-sticky"|not)) | .id'
    case "focus-window-id"
        argparse wait-focus -- $argv
        or return 1
        set window_id $argv[1]
        set -e argv[1]


        # Without --wait-focus, simplify algorithm
        if not set -q _flag_wait_focus
            # Restore the window first if it's minimized. Focusing a minimized window
            # activates the app before the window can become key, so macOS surfaces a
            # different (non-minimized) window of the same app first. Deminimizing up
            # front avoids that flash.
            set is_min (yabai -m query --windows --window "$window_id" 2>/dev/null | jq -r '."is-minimized"')
            if test "$is_min" = "true"
                yabai -m window --deminimize "$window_id"
            else
                yabai -m window --focus "$window_id"
            end
        end


        # Cross-space focus: switching spaces takes time, so poll until the
        # window is actually focused, then settle briefly before returning.
        # ~3s timeout: 60 polls spaced 0.05s apart.
        set target_space (yabai -m query --windows --window "$window_id" | jq -r '.space')
        set current_space (yabai -m query --spaces --space | jq -r '.index')

        yabai -m window --focus "$window_id"

        # If window already in current space, no need to wait further
        if test "$target_space" = "$current_space"
            return
        end

        for i in (seq 60)
            if test (yabai-preset get-focused-window-id) = "$window_id"
                sleep 0.3
                return 0
            end
            sleep 0.05
        end
        echo "focus-window-id: timed out waiting for window $window_id to focus" >&2
        return 1
    case "focus-window"
        set direction $argv[1]
        set -e argv[1]

        switch "$direction"
            case next prev
                yabai-preset focus-window-in-space $direction
                return $status
            case '*'
                yabai -m window --focus $direction
                or return 1
        end
    case "get-visible-window-id"
        set direction $argv[1]
        set -e argv[1]

        # Among the foreground-visible windows of the current space (computed by
        # list-visible-windows), pick the nearest one in the requested direction
        # relative to the focused/topmost window.
        yabai-preset list-visible-windows --threshold 0.01 \
        | jq -ser --arg dir "$direction" '
        (first(.[] | select(."has-focus")) // max_by(.z_index)) as {$id, $title, frame: $zero}
        | ($zero |
            if $dir == "east" then {x: (.x + .w), y: (.y/2 + .h/2)}
            elif $dir == "west" then {x: .x, y: (.y/2 + .h/2)}
            elif $dir == "south" then {x: (.x/2 + .w/2), y: (.y + .h)}
            elif $dir == "north" then {x: (.x/2 + .w/2), y: .y}
            end | . + {w: $zero.w, h: $zero.h}) as $zero
        | sort_by(
            if $dir == "east" then [.frame.x + .frame.w, .id]
            elif $dir == "west" then [-.frame.x, -.id]
            elif $dir == "south" then [.frame.y + .frame.h, .id]
            elif $dir == "north" then [-.frame.y, -.id]
            end
        )
        | .[(map(.id) | index($id))+1:]
        | map(.distance =
            if $dir == "east" then ([.frame.x + .frame.w, .frame.x]|map(.-$zero.x|select(.>0))|min) + ([.frame.y/2 + .frame.h/2 - $zero.y - $zero.h/2, 0]|max)
            elif $dir == "west" then ([.frame.x + .frame.w, .frame.x]|map($zero.x-.|select(.>0))|min) + ([.frame.y/2 + .frame.h/2 - $zero.y - $zero.h/2, 0]|max)
            elif $dir == "south" then ([.frame.x/2 + .frame.w/2 - $zero.x - $zero.w/2, 0]|max) + ([.frame.y + .frame.h, .frame.y]|map(.-$zero.y|select(.>0))|min)
            elif $dir == "north" then ([.frame.x/2 + .frame.w/2 - $zero.x - $zero.w/2, 0]|max) + ([.frame.y + .frame.h, .frame.y]|map($zero.y-.|select(.>0))|min)
            end)
        | sort_by([.distance, -.z_index])
        | first.id'
        or return 1
    case "focus-visible-window"
        set direction $argv[1]
        set -e argv[1]

        set winid (yabai-preset get-visible-window-id $direction)
        or return 1
        yabai -m window "$winid" --focus
        or return 1
    case "get-floating-window-id"
        set direction $argv[1]
        set -e argv[1]

        set is_layout_float (yabai-preset is-space-float-layout && echo true || echo false)

        if test "$is_layout_float" = true
            set ids_json (yabai -m query --windows --space | jq -c '[.[] | select(."is-visible" and (."is-sticky"|not)) | .id]')
        else
            set ids_json (yabai -m query --windows --space | jq -c '[.[] | select(."is-visible" and (."is-sticky"|not) and ."split-type" == "none" and ."is-floating") | .id]')
        end

        set focused_id (yabai -m query --windows --space | jq -r 'first(.[] | select(."has-focus")) // .[-1] | .id')

        yabai-preset get-floating-window-target --ids "$ids_json" --focused "$focused_id" $direction
        or return 1
    case "focus-space"
        set space $argv[1]
        set -e argv[1]

        if contains "$space" "next" "prev" "recent"
            set space (yabai -m query --spaces --space "$space" | jq .index)
        end

        osascript-preset send-keys ctrl $space
    case "move-window-to-space"
        set space $argv[1]
        set -e argv[1]

        if contains "$space" "next" "prev" "recent"
            set space (yabai -m query --spaces --space "$space" | jq .index)
        end

        hs-preset move-window-to-space $space
    case "move-window-ids-to-space"
        # Move each window id to the given space. Because the move is a drag
        # gesture on the focused window, we focus each one (waiting for the
        # cross-space switch) before moving it, then let the drag settle.
        argparse 'space=' -- $argv
        or return 1
        set space $_flag_space
        set ids $argv

        for id in $ids
            yabai-preset focus-window-id --wait-focus "$id"
            or begin
                echo "move-window-ids-to-space: failed to focus window $id" >&2
                return 1
            end
            yabai-preset move-window-to-space "$space"
            sleep 0.7
        end
    case "focus-window-in-stack"
        set stack $argv[1]
        set -e argv[1]

        if not yabai -m query --windows --window | jq -e '.id' > /dev/null
            yabai-preset focus-topmost
            return
        end

        if contains "$stack" "next" "prev" "recent" "first" "last"
            set stack (yabai -m query --windows --window "stack.$stack" | jq -e '."stack-index"')
        end

        if not test -n "$stack" -a "$stack" -gt 0
            return 1
        end

        set last (yabai -m query --windows --window "stack.last" | jq -e '."stack-index"')
        yabai -m window --focus "stack.$stack"
        display-message "Stack $stack / $last"
    case "focus-window-in-space"
        argparse -i \
            'floating-only=?' \
            -- $argv

        set window $argv[1]
        set -e argv[1]

        if not yabai -m query --windows --window | jq -e '.id' > /dev/null
            yabai-preset focus-topmost
            return
        end

        if not contains "$window" "next" "prev" "first" "last"
            echo "Invalid argument: $window" >&2
            return 1
        end

        set floating_only (test -n "$_flag_floating_only" && echo "true" || echo "false")
        set is_layout_float (yabai-preset is-space-float-layout && echo true || echo false)

        yabai -m query --windows --space | jq -er --arg window "$window" --argjson floating_only "$floating_only" --argjson is_layout_float "$is_layout_float" '.
        | map(select(."is-visible" and (."is-sticky"|not) and (if $is_layout_float then true elif $floating_only then ."split-type" == "none" and ."is-floating" else true end)))
            | (first(.[] | select(."has-focus")) // .[0]).id as $focus
            | sort_by([
                # Floating windows appear last
                if ."split-type" == "none" and ."is-floating" then 2
                else 1 end,
                .frame.x,
                .frame.y,
                ."stack-index",
                .id
            ])
            | (map(.id) | index($focus)) as $pos
            | ({first: 0, last: (length - 1), prev: ([0, $pos - 1]|max), next: ([length - 1, $pos + 1]|min)}[$window]) as $window_pos
            | "\(.[$window_pos].id):\($window_pos+1):\(length)" ' | read -d: window window_pos total

        yabai -m window --focus "$window"

        if set -q $_flag_floating_only
            display-message "Floating $window_pos / $total"
        else
            display-message "Windows $window_pos / $total"
        end
    case "focus-floating-window-in-space"
        yabai-preset focus-floating-window $argv
    case "focus-floating-window"
        set direction $argv[1]
        set -e argv[1]

        set winid (yabai-preset get-floating-window-id $direction)
        or return 1
        yabai -m window "$winid" --focus
        or return 1
    case "focus-stack-aware"
        set direction $argv[1]
        set -e argv[1]

        if yabai-preset is-window-floating
            # Floating: try floating→floating, fallback to stack top
            yabai-preset focus-floating-window $direction
            or begin
                set stack_win (yabai -m query --windows --space | jq -r '
                    [.[] | select(."is-visible" and (."is-sticky"|not) and (."is-floating" | not) and ."stack-index" > 0)]
                    | (map(select(."has-focus"))[0] // .[0]).id // empty')
                test -n "$stack_win"; and yabai -m window --focus "$stack_win"
            end
        else
            # Stack: find nearest floating window in direction using stack position as reference
            set focused_id (yabai-preset get-focused-window-id)
            set floating_ids (yabai -m query --windows --space | jq -c \
                '[.[] | select(."is-visible" and (."is-sticky"|not) and ."split-type" == "none" and ."is-floating") | .id]')
            set all_ids (echo "$floating_ids" | jq -c --argjson fid "$focused_id" '. + [$fid]')

            set target (yabai-preset get-floating-window-target --ids "$all_ids" --focused "$focused_id" $direction)
            test -n "$target"; and yabai -m window --focus "$target"
        end
    case "move-window-in-stack"
        set stack $argv[1]
        set -e argv[1]

        if contains "$stack" "next" "prev" "recent" "first" "last"
            set stack (yabai -m query --windows --window "stack.$stack" | jq -e '."stack-index"')
        end

        if not test -n "$stack" -a "$stack" -gt 0
            return
        end

        set last (yabai -m query --windows --window "stack.last" | jq -e '."stack-index"')
        yabai -m window --swap "stack.$stack"
        yabai -m window --focus "stack.$stack"
        display-message "Stack $stack / $last"
    case "focus-display-with-fallback"
        set display $argv[1]
        set -e argv[1]

        set target_display_index (yabai -m query --displays --display "$display" 2>/dev/null | jq -r '.index')

        if test -z "$target_display_index"
            if test "$display" = north -o "$display" = west
                set target_display_index (yabai -m query --displays --display prev 2>/dev/null | jq -r '.index')
            else
                set target_display_index (yabai -m query --displays --display next 2>/dev/null | jq -r '.index')
            end
        end

        if test -z "$target_display_index"
            return 1
        end

        set win_id (yabai -m query --windows | jq -r "[.[] | select(.display == $target_display_index and .\"is-visible\" == true and .\"is-sticky\" == false)] | first | .id // empty")

        if test -n "$win_id"
            yabai -m window --focus "$win_id"
        else
            yabai -m display --focus "$display"
        end
    case "smart-move-window-to-next-display"
        set win (yabai-preset get-focused-window-id)

        if yabai-preset is-window-floating
            hs-preset move-window-to-next-screen
            yabai -m window --focus "$win"
        else
            yabai -m window "$win" --toggle float
            yabai -m window --focus "$win"
            hs-preset move-window-to-next-screen
            yabai -m window "$win" --toggle float
        end
    case "stack-or-warp-window"
        set direction $argv[1]
        set -e argv[1]

        if yabai -m query --windows --window | jq -e '."stack-index" > 0'
            yabai -m window --warp "$direction"
        else
            yabai -m window --stack "$direction"
        end
    case "stack-windows-in-space"
        set query '.
            | map(select(."is-visible" and (."is-sticky"|not)))
            | (first(.[] | select(."has-focus")) // .[0]) as $focus
            | [$focus.id] + map(select($focus.id != .id) | .id)
            | .[]'
        set windows (yabai -m query --windows --space | jq -er "$query")

        set current $windows[1]
        yabai -m window "$current" (printf "--stack\n%s\n" $windows[2..])

        # Hack: When using two monitors, some windows down in the tree get "pushed"
        # to the other monitor and might not be properly captured by the query command,
        # so we need to do a second passing
        set second_passing (yabai -m query --windows --space | jq -er "$query")

        for window in $second_passing
            if not contains "$window" $windows
                yabai -m window "$current" --stack "$window"
            end
        end

        display-message "$(count $second_passing) windows stacked"
    case "stack-window-ids"
        # Stack the given window ids together; the first id is the stack base.
        set ids $argv
        if test (count $ids) -lt 2
            echo "stack-window-ids: need at least 2 windows" >&2
            return 1
        end

        yabai-preset focus-window-id $ids[1]
        yabai-preset enforce-tiling --tiling $ids[1]

        for id in $ids[2..]
            # While the previous window is focused, point its insertion at the
            # stack, then re-tile the next window so it joins that stack.
            yabai-preset insert-direction stack
            yabai-preset focus-window-id $id
            yabai-preset enforce-tiling --floating $id
            yabai-preset enforce-tiling --tiling $id
        end
    case "stack-after-nth-window"
        set nth $argv[1]
        set -e argv[1]

        set windows (yabai -m query --windows --space | jq -er --argjson nth "$nth" '.
            | map(select(."is-visible" and (."is-sticky"|not)))
            | .[$nth-1:]
            | .[].id')

        set nth_window $windows[1]
        yabai -m window "$nth_window" (printf "--stack\n%s\n" $windows[2..])
        display-message "$(count $windows) windows stacked"
    case "minimize-after-nth-window"
        set nth $argv[1]
        set -e argv[1]

        set windows (yabai -m query --windows --space | jq -er --argjson nth "$nth" '.
            | map(select(."is-visible" and (."is-sticky"|not)))
            | .[$nth:]
            | .[].id')

        for window in $windows
            yabai -m window "$window" --minimize
        end

        display-message "$(count $windows) windows minimized"
    case "minimize"
        set window $argv[1]
        set -e argv[1]

        # Default to the focused window when no id is given.
        test -z "$window"; and set window (yabai-preset get-focused-window-id)

        # Some apps (e.g. Chrome "app" windows created via chrome-preset) hijack
        # focus to another of their windows when minimized, which overrides a
        # post-minimize focus and leaves us on the wrong window. Focus the recent
        # window first and then minimize the original by id so focus lands where
        # we want.
        set recent (yabai-preset get-recent-window-id)
        and yabai -m window --focus "$recent"
        yabai -m window "$window" --minimize
        display-message -t 0.3 "Minimize"
    case "focus-topmost"
        yabai -m window --focus (yabai -m query --windows --space | jq 'first(.[] | select(."is-visible" and (."is-sticky"|not))).id')
    case "deminimize-last"
        set window (yabai -m query --windows | jq 'map(select(."is-minimized")) | first | .id')
        yabai -m window --deminimize "$window"
        yabai -m window --focus "$window"
    case "deminimize-all"
        set minimized (yabai -m query --windows | jq -er 'map(select(."is-minimized")) | .[].id')

        for window in $minimized
            yabai -m window --deminimize "$window"
        end
    case "hide-after-nth-window"
        set nth $argv[1]
        set -e argv[1]

        set apps (yabai -m query --windows --space | jq -er --argjson nth "$nth" '.
            | map(select(."is-visible" and (."is-sticky"|not)))
            | (.[:$nth-1] | map(.app) | unique) as $seen_apps
            | .[$nth:]
            | map(.app) - $seen_apps
            | .[]')

        for app in $apps
            osascript -e "tell application \"System Events\" to set visible of process \"$app\" to false"
        end

        display-message "$(count $apps) apps hidden"
    case "unstack-window"
        set direction $argv[1]
        set -e argv[1]

        yabai -m window --insert "$direction" --toggle float --toggle float
    case "arrange-spaces"
        argparse -i \
            'a/app=+' \
            'w/window=+' \
            -- $argv

        for line in "app:"$_flag_app "title:"$_flag_window
            echo $line | read -l -d: format space filter

            for line2 in (yabai -m query --windows | jq -er --arg format "$format" --argjson space "$space" '.[] | select(.space != $space) | "\(.id):\(.[$format]):"' | string match -er ":$filter:")
                echo $line2 | read -l -d: window __

                set -a specs "$space:$window"
            end
        end


        for line in $specs
            echo $line | read -d: space window
            yabai -m window "$window" --focus
            sleep 0.5
            yabai-preset move-window-to-space "$space"
        end

    case "is-window-floating"
        set window $argv[1]; set -e argv[1]

        yabai -m query --windows --window "$window" \
        | jq -r '.space, ."is-floating"' \
        | read --line space is_floating

        if yabai -m query --spaces --space "$space" | jq -e '.type == "float"' >/dev/null
            return 0
        end

        test "$is_floating" = true
        or return 1
    case "enforce-tiling"
        # Force a window into a floating/tiling state (or toggle it).
        # Usage: enforce-tiling --floating|--tiling|--toggle [window_id]
        argparse floating tiling toggle -- $argv
        or return 1
        set window $argv[1]; set -e argv[1]
        test -z "$window"; and set window (yabai-preset get-focused-window-id)

        if set -q _flag_toggle
            yabai -m window "$window" --toggle float
        else if set -q _flag_floating
            yabai-preset is-window-floating "$window"; or yabai -m window "$window" --toggle float
        else if set -q _flag_tiling
            not yabai-preset is-window-floating "$window"; or yabai -m window "$window" --toggle float
        else
            echo "enforce-tiling: specify --floating, --tiling or --toggle" >&2
            return 1
        end
    case "is-space-float-layout"
        set space $argv[1]
        set -e argv[1]

        yabai -m query --spaces --space "$space" | jq -e '.type == "float"' >/dev/null
        or return 1
    case "is-space-stack-layout"
        set space $argv[1]
        set -e argv[1]

        yabai -m query --spaces --space "$space" | jq -e '.type == "stack"' >/dev/null
        or return 1
    case "is-window-fullscreen"
        set window $argv[1]
        set -e argv[1]

        if test -z "$window"
            set window (yabai -m query --windows | jq -r 'first(.[] | select(."has-focus")) | .id')
        end

        yabai -m query --windows --window "$window" | jq -r '.frame.w, .frame.h, .display' | read --line w h display
        yabai -m query --displays --display "$display" | jq -r '.frame | .w, .h' | read --line display_w display_h

        test "$(math "0.9 * $display_w")" -le "$w" -a "$(math "0.9 * $display_h")" -le "$h"
        or return 1
    case "toggle-window-zoom-or-fullscreen"
        set window $argv[1]
        set -e argv[1]

        if test -z "$window"
            set window (yabai -m query --windows | jq -r 'first(.[] | select(."has-focus")) | .id')
        end

        if yabai-preset is-window-floating "$window"
            if yabai-preset is-window-fullscreen "$window"
                yabai-preset restore-window-position
            else
                yabai-preset store-window-position
                yabai -m window "$window" --grid "1:1:0:0:1:1"
            end
        else
            yabai -m window "$window" --toggle zoom-fullscreen
        end
    case "toggle-monocle-mode"
        if yabai -m query --windows --window | jq -re '."has-fullscreen-zoom"' > /dev/null
            display-message "Exit Monocle"
            set fullscreen true
        else
            display-message "Enter Monocle"
            set fullscreen false
        end

        set windows (yabai -m query --windows --space | jq -re --argjson fullscreen "$fullscreen" '
            .[]
            | debug($fullscreen)
            | select(
                ."is-visible"
                and (."is-sticky" | not)
                and (."stack-index" <= 1)
                and (."has-fullscreen-zoom" == $fullscreen))
            | .id')

        for window in $windows
            echo window "$window"
            yabai -m window "$window" --toggle zoom-fullscreen
        end
    case "smart-toggle-fullscreen"
        if yabai-preset is-window-floating
            yabai-preset toggle-window-zoom-or-fullscreen
        else
            yabai-preset toggle-monocle-mode
        end
    case "toggle-yabai"
        yabai --stop-service
        and display-message "Yabai Stopped"
        or begin
            yabai --start-service
            and display-message "Yabai Started"
        end

    case "init-window-db"
        mkdir -p (path dirname "$DB_PATH")
        sqlite3 "$DB_PATH" "CREATE TABLE IF NOT EXISTS window_positions (
            window_id INTEGER PRIMARY KEY,
            x REAL NOT NULL,
            y REAL NOT NULL,
            w REAL NOT NULL,
            h REAL NOT NULL
        );"
    case "store-window-position"
        set winid $argv[1]; set -e argv[1]

        set window (yabai -m query --windows --window "$window")

        yabai-preset is-window-floating "$winid" || return 1
        yabai-preset is-window-fullscreen "$winid" && return 1

        set winid (jq -nr --argjson window "$window" '$window.id')
        jq -nr --argjson window "$window" '$window.frame | "\(.x)\n\(.y)\n\(.w)\n\(.h)"' \
        | read --line x y w h

        yabai-preset init-window-db
        sqlite3 "$DB_PATH" "INSERT OR REPLACE INTO window_positions (window_id, x, y, w, h)
            VALUES ($winid, $x, $y, $w, $h);"
    case "restore-window-position"
        set winid $argv[1]; set -e argv[1]

        set winid (test -n "$winid"; and echo "$winid"; or yabai-preset get-focused-window-id)

        yabai-preset init-window-db
        sqlite3 "$DB_PATH" "SELECT x, y, w, h FROM window_positions WHERE window_id = $winid;" \
        | string replace -a '|' \n | read --line x y w h
        or return 1

        and yabai -m window "$winid" --move "abs:$x:$y"
        and yabai -m window "$winid" --resize "abs:$w:$h"
    case "print-window-mode"
        set winid $argv[1]; set -e argv[1]
        yabai -m query --windows --window | jq -r '.id, ."stack-index", ."has-fullscreen-zoom"' | read --line id stack_index has_zoom

        if test -z "$id" -o -z "$stack_index"
            return
        end

        if yabai-preset is-window-floating
            echo "float"
        else if test "$stack_index" -gt 0
            yabai -m query --windows --window stack.last | jq -r '."stack-index"' | read --line stack_count
            echo "stack $stack_index/$stack_count"
        else if test "$has_zoom" = true
            echo "zoom"
        else
            echo "tile"
        end
    case "print-yabai-widget"
        yabai -m query --spaces \
        | jq -r 'length, (map(select(."has-focus"))[0] | .index, .type)' \
        | read --line spaces_count space_number space_mode

        set window_mode "$(yabai-preset print-window-mode)"

        echo "$space_mode:$space_number/$spaces_count ($window_mode)"
    case "unstacked-swap-largest"
        set focus_id (yabai-preset get-focused-window-id)

        if yabai -m query --windows --window | jq -e '."stack-index" > 0'
            set pending_stack_id (yabai -m query --windows --window largest | jq -r '.id')
            yabai-preset unstack-window east
        end

        yabai -m window --swap largest

        if set -q pending_stack_id
            yabai -m window --focus "$pending_stack_id"
            yabai -m window west --stack "$pending_stack_id"
            yabai -m window --focus "$pending_stack_id"
            yabai -m window --focus "$focus_id"
        end
    case "focus-pid"
        set pid $argv[1]
        set -e argv[1]

        yabai -m query --windows \
        | jq -re --argjson pid "$pid" '.
        | first(.[] | select(.pid == $pid))
        | .id
        ' \
        | read --line window
        or return 1

        yabai -m window "$window" --focus
    case "minimize-pid"
        set pid $argv[1]
        set -e argv[1]

        yabai -m query --windows \
        | jq -re --argjson pid "$pid" '.
        | first(.[] | select(.pid == $pid))
        | .id
        ' \
        | read --line window
        or return 1

        yabai-preset minimize "$window"
    case "stack-new-window"
        set winid $argv[1]; set -e argv[1]
        set window (yabai -m query --windows --window "$window" | string collect)
        set recent (yabai -m query --windows --window recent | string collect)

        if jq -ne --argjson window "$window" '
                ($window."split-type" == "none")
                or (($window.app == "Google Chrome") and ($window.title | IN("Picture in Picture", "")))' > /dev/null
            return
        end

        if test -n "$recent"; and jq -ne --argjson recent "$recent" '$recent."stack-index" > 0' > /dev/null
            yabai -m window "$(jq -n --argjson recent "$recent" '$recent.id')" --stack "$winid"
        end
    case "get-window-info"
        set windowid $argv[1]
        set -e argv[1]

        yabai -m query --windows | jq -e --argjson windowid "$windowid" 'first(.[] | select(.id == $windowid))'
        return $status
    case "swap-window"
        set direction $argv[1]
        set -e argv[1]
        yabai -m window --swap $direction
        or return 1
    case "warp-window"
        set direction $argv[1]
        set -e argv[1]
        yabai -m window --warp $direction; or yabai-preset unstack-window $direction
    case "toggle-float"
        if yabai-preset is-space-float-layout
            echo "Unsupported in float layout"
            return 1
        end

        if yabai-preset is-window-floating
            yabai-preset enforce-tiling --tiling
            echo tiling
            return
        end

        if yabai-preset is-space-stack-layout
            # Detect padding direction before toggling
            yabai -m query --windows --window | jq -r '.frame | "\(.x)\n\(.y)\n\(.w)\n\(.h)"' \
                | read --line stk_x stk_y stk_w stk_h
            yabai -m query --displays --display | jq -r '.frame | "\(.x)\n\(.y)\n\(.w)\n\(.h)"' \
                | read --line dsp_x dsp_y dsp_w dsp_h

            set left_space (math "round($stk_x - $dsp_x)")
            set right_space (math "round($dsp_x + $dsp_w - $stk_x - $stk_w)")
            set top_space (math "round($stk_y - $dsp_y)")
            set bottom_space (math "round($dsp_y + $dsp_h - $stk_y - $stk_h)")
            set h_threshold (math "round(0.1 * $dsp_w)")
            set v_threshold (math "round(0.1 * $dsp_h)")

            # Find the side with the most padding
            set -l best_space 0
            set -l best_dir ""
            if test "$right_space" -gt "$h_threshold" -a "$right_space" -ge "$best_space"
                set best_space $right_space; set best_dir east
            end
            if test "$left_space" -gt "$h_threshold" -a "$left_space" -gt "$best_space"
                set best_space $left_space; set best_dir west
            end
            if test "$bottom_space" -gt "$v_threshold" -a "$bottom_space" -gt "$best_space"
                set best_space $bottom_space; set best_dir south
            end
            if test "$top_space" -gt "$v_threshold" -a "$top_space" -gt "$best_space"
                set best_space $top_space; set best_dir north
            end

            yabai-preset enforce-tiling --floating

            if test -n "$best_dir"
                switch "$best_dir"
                    case east west
                        set gap_frac (math "$best_space / $dsp_w")
                    case north south
                        set gap_frac (math "$best_space / $dsp_h")
                end
                yabai-preset snap --frac "$gap_frac" $best_dir
            else
                yabai -m window --grid "8:8:1:1:6:6"
            end
        else
            yabai-preset enforce-tiling --floating
            yabai -m window --grid "8:8:1:1:6:6"
        end
        echo floating
    case "toggle-split"
        yabai -m window --toggle split
    case "balance"
        yabai -m space --balance
    case "resize"
        # Translate aerospace-style resize args to yabai
        # e.g. "resize smart +100" or "resize width +100"
        set resize_type $argv[1]
        set -e argv[1]
        set amount $argv[1]
        set -e argv[1]

        switch "$resize_type"
            case smart width
                yabai -m window --resize bottom_right:$amount:0
            case height
                yabai -m window --resize bottom_right:0:$amount
        end
    case "focus-back-and-forth"
        yabai -m window --focus recent
    case "restart-wm"
        yabai --stop-service && yabai --start-service
        and display-message "Yabai Restarted"
        or begin
            yabai --start-service
            and display-message "Yabai Started"
        end
    case "toggle-wm"
        yabai-preset toggle-yabai
    case "print-wm-widget"
        yabai-preset print-yabai-widget
    case "layout-stack"
        yabai -m space --layout stack
        display-message "Layout stack"
    case "layout-bsp"
        yabai-preset set-stack-default-padding
        yabai -m space --layout bsp
        display-message "Layout bsp"
    case "layout-float"
        yabai-preset set-stack-default-padding
        yabai -m space --layout float
        display-message "Layout float"
    case "layout-float-all"
        for space in (yabai -m query --spaces | jq -r '.[].index')
            yabai -m space "$space" --layout float
        end
        display-message "Layout float (all spaces)"
    case "flatten"
        display-message "Not supported in yabai"
    case "insert-direction"
        set direction $argv[1]
        set -e argv[1]
        yabai -m window --insert $direction
    case "mirror"
        set axis $argv[1]
        set -e argv[1]
        yabai -m space --mirror $axis
    case "rotate"
        set deg $argv[1]
        set -e argv[1]
        yabai -m space --rotate $deg
    case "get-floating-window-target"
        argparse \
            'ids=' \
            'focused=' \
            -- $argv
        or return 1

        set direction $argv[1]
        set -e argv[1]

        switch "$direction"
            case next prev first last
                yabai -m query --windows | jq -er \
                    --argjson ids "$_flag_ids" \
                    --argjson focused "$_flag_focused" \
                    --arg dir "$direction" '
                    map(select((.id as $id | $ids | index($id)) and (.["is-sticky"] | not)))
                    | sort_by([.frame.x, .frame.y, .id])
                    | (map(.id) | index($focused)) as $pos
                    | if $pos == null then first.id
                      else ({first: 0, last: (length - 1), prev: ($pos - 1), next: ($pos + 1)}[$dir]) as $target
                      | if $target < 0 or $target >= length then null
                        else .[$target].id end
                      end'
                or return 1
            case east west north south
                yabai -m query --windows | jq -er \
                    --argjson ids "$_flag_ids" \
                    --argjson focused "$_flag_focused" \
                    --arg dir "$direction" '
                    map(select((.id as $id | $ids | index($id)) and (.["is-sticky"] | not)))
                    | (first(.[] | select(.id == $focused)) // .[0]) as $cur
                    | map(select(.id != $focused))
                    | map(select(
                        if $dir == "east" then .frame.x >= ($cur.frame.x + $cur.frame.w / 2)
                        elif $dir == "west" then (.frame.x + .frame.w) <= ($cur.frame.x + $cur.frame.w / 2)
                        elif $dir == "south" then .frame.y >= ($cur.frame.y + $cur.frame.h / 2)
                        elif $dir == "north" then (.frame.y + .frame.h) <= ($cur.frame.y + $cur.frame.h / 2)
                        else false end))
                    | sort_by(
                        ((.frame.x + .frame.w/2) - ($cur.frame.x + $cur.frame.w/2)) as $dx
                        | ((.frame.y + .frame.h/2) - ($cur.frame.y + $cur.frame.h/2)) as $dy
                        | ($dx*$dx + $dy*$dy))
                    | first.id'
                or return 1
            case '*'
                echo "Invalid direction: $direction" >&2
                return 1
        end
    case "get-recent-window-id"
        yabai -m query --windows --space | jq -er '
            first(.[] | select(."is-visible" and (."is-sticky"|not) and (."has-focus"|not) and ."can-resize"))
            | .id'
        or return 1
    case "focus-recent"
        set recent (yabai-preset get-recent-window-id)
        or return 1
        yabai -m window --focus "$recent"
    case "get-visible-frame"
        # Output "x\ny\nw\nh" of the usable area (excludes menu bar and dock) of
        # the display containing the given window (default: focused window).
        set window $argv[1]; set -e argv[1]
        test -z "$window"; and set window (yabai-preset get-focused-window-id)

        yabai -m query --windows --window "$window" | jq -r '.frame.x' | read --line win_x
        # NSScreen.visibleFrame gives the usable area; yabai --move/--resize abs:
        # uses raw screen coords, so convert the origin to top-left space.
        osascript -l JavaScript -e "
            ObjC.import('AppKit');
            var wx = $win_x;
            var screens = \$.NSScreen.screens;
            var s = \$.NSScreen.mainScreen;
            for (var i = 0; i < screens.count; i++) {
                var sf = screens.objectAtIndex(i).frame;
                if (wx >= sf.origin.x && wx < sf.origin.x + sf.size.width) { s = screens.objectAtIndex(i); break; }
            }
            var f = s.frame;
            var vf = s.visibleFrame;
            var y = f.size.height - vf.origin.y - vf.size.height + f.origin.y;
            [Math.round(vf.origin.x), Math.round(y), Math.round(vf.size.width), Math.round(vf.size.height)].join('\n');
        "
    case "side-by-side"
        # Arrange the given window ids into an optimal grid on their display.
        set ids $argv

        set n (count $ids)
        if test "$n" -lt 2 -o "$n" -gt 6
            echo "side-by-side: need between 2 and 6 windows (got $n)" >&2
            return 1
        end

        # Make every target window floating so it can be positioned freely.
        for id in $ids
            yabai-preset enforce-tiling --floating "$id"
        end

        # Usable area of the display that holds the first window.
        yabai-preset get-visible-frame "$ids[1]" | read --line dsp_x dsp_y dsp_w dsp_h

        set gap (yabai -m config window_gap | string trim)
        set tp (yabai -m config top_padding | string trim)
        set bp (yabai -m config bottom_padding | string trim)
        set lp (yabai -m config left_padding | string trim)
        set rp (yabai -m config right_padding | string trim)

        set ox (math "$dsp_x + $lp")
        set oy (math "$dsp_y + $tp")
        set uw (math "$dsp_w - $lp - $rp")
        set uh (math "$dsp_h - $tp - $bp")

        # Bands = windows per band. Bands stack along the screen's short axis and
        # split along the long axis, giving each window the most room.
        switch "$n"
            case 2
                set bands 2
            case 3
                set bands 3
            case 4
                set bands 2 2
            case 5
                set bands 2 3
            case 6
                set bands 3 3
        end

        set num_bands (count $bands)
        set idx 1

        if test "$uh" -gt "$uw"
            # Vertical display: bands are columns split into stacked rows.
            set band_w (math "($uw - $gap * ($num_bands - 1)) / $num_bands")
            for b in (seq $num_bands)
                set size $bands[$b]
                set x (math "floor($ox + ($b - 1) * ($band_w + $gap))")
                set w (math "floor($band_w)")
                set cell_h (math "($uh - $gap * ($size - 1)) / $size")
                for r in (seq $size)
                    set y (math "floor($oy + ($r - 1) * ($cell_h + $gap))")
                    set h (math "floor($cell_h)")
                    set id $ids[$idx]
                    yabai -m window "$id" --move "abs:$x:$y"
                    yabai -m window "$id" --resize "abs:$w:$h"
                    set idx (math "$idx + 1")
                end
            end
        else
            # Horizontal display: bands are rows split into side-by-side columns.
            set band_h (math "($uh - $gap * ($num_bands - 1)) / $num_bands")
            for r in (seq $num_bands)
                set size $bands[$r]
                set y (math "floor($oy + ($r - 1) * ($band_h + $gap))")
                set h (math "floor($band_h)")
                set cell_w (math "($uw - $gap * ($size - 1)) / $size")
                for c in (seq $size)
                    set x (math "floor($ox + ($c - 1) * ($cell_w + $gap))")
                    set w (math "floor($cell_w)")
                    set id $ids[$idx]
                    yabai -m window "$id" --move "abs:$x:$y"
                    yabai -m window "$id" --resize "abs:$w:$h"
                    set idx (math "$idx + 1")
                end
            end
        end
    case "snap"
        argparse 'frac=' -- $argv
        or return 1

        set direction $argv[1]
        set -e argv[1]

        set gap (yabai -m config window_gap | string trim)
        set tp (yabai -m config top_padding | string trim)
        set bp (yabai -m config bottom_padding | string trim)
        set lp (yabai -m config left_padding | string trim)
        set rp (yabai -m config right_padding | string trim)

        yabai -m query --windows --window | jq -r '.frame | "\(.x)\n\(.y)\n\(.w)\n\(.h)"' | read --line win_x win_y win_w win_h
        # NSScreen.visibleFrame gives the usable area (excludes menu bar and dock).
        # yabai's display frame includes the menu bar, and --move/--resize abs: uses raw screen coords.
        # Find the screen containing the focused window by matching its position.
        osascript -l JavaScript -e "
            ObjC.import('AppKit');
            var wx = $win_x, wy = $win_y;
            var screens = \$.NSScreen.screens;
            var s = \$.NSScreen.mainScreen;
            for (var i = 0; i < screens.count; i++) {
                var sf = screens.objectAtIndex(i).frame;
                if (wx >= sf.origin.x && wx < sf.origin.x + sf.size.width) { s = screens.objectAtIndex(i); break; }
            }
            var f = s.frame;
            var vf = s.visibleFrame;
            var y = f.size.height - vf.origin.y - vf.size.height + f.origin.y;
            [Math.round(vf.origin.x), Math.round(y), Math.round(vf.size.width), Math.round(vf.size.height)].join('\n');
        " | read --line dsp_x dsp_y dsp_w dsp_h

        set uw (math "$dsp_w - $lp - $rp")
        set uh (math "$dsp_h - $tp - $bp")

        # Snap fractions cycle in this order. Edit this array to tune sizes.
        set -l snap_fracs (math "1/2") (math "2/3") (math "1/3")

        if set -q _flag_frac
            set frac (math "$_flag_frac")
        else
            # Detect if window is already on the target side
            set -l on_side false
            set -l dim_ratio 0
            switch "$direction"
                case west
                    test (math "round(0.05 * $dsp_w - ($win_x - $dsp_x))") -gt 0; and set on_side true
                    set dim_ratio (math "$win_w / $dsp_w")
                case east
                    test (math "round(0.05 * $dsp_w - ($dsp_x + $dsp_w - $win_x - $win_w))") -gt 0; and set on_side true
                    set dim_ratio (math "$win_w / $dsp_w")
                case north
                    test (math "round(0.05 * $dsp_h - ($win_y - $dsp_y))") -gt 0; and set on_side true
                    set dim_ratio (math "$win_h / $dsp_h")
                case south
                    test (math "round(0.05 * $dsp_h - ($dsp_y + $dsp_h - $win_y - $win_h))") -gt 0; and set on_side true
                    set dim_ratio (math "$win_h / $dsp_h")
            end

            # Cycle through snap_fracs: match current ratio → advance to next
            set frac $snap_fracs[1]
            if test "$on_side" = true
                set -l n (count $snap_fracs)
                for i in (seq $n)
                    set -l diff (math "round(abs($dim_ratio - $snap_fracs[$i]) * 1000)")
                    if test "$diff" -lt 50
                        set -l next (math "$i % $n + 1")
                        set frac $snap_fracs[$next]
                        break
                    end
                end
            end
        end

        # Only snap the relevant dimension so corners can be composed
        # (e.g. snap west then snap north → top-left quarter)
        switch "$direction"
            case west
                set x (math "floor($dsp_x + $lp)")
                set w (math "floor($uw * $frac - $gap / 2)")
                yabai -m window --move "abs:$x:$win_y"
                yabai -m window --resize "abs:$w:$win_h"
            case east
                set x (math "floor($dsp_x + $lp + $uw * (1 - $frac) + $gap / 2)")
                set w (math "floor($uw * $frac - $gap / 2)")
                yabai -m window --move "abs:$x:$win_y"
                yabai -m window --resize "abs:$w:$win_h"
            case north
                set y (math "floor($dsp_y + $tp)")
                set h (math "floor($uh * $frac - $gap / 2)")
                yabai -m window --move "abs:$win_x:$y"
                yabai -m window --resize "abs:$win_w:$h"
            case south
                set y (math "floor($dsp_y + $tp + $uh * (1 - $frac) + $gap / 2)")
                set h (math "floor($uh * $frac - $gap / 2)")
                yabai -m window --move "abs:$win_x:$y"
                yabai -m window --resize "abs:$win_w:$h"
            case '*'
                echo "Invalid argument: $direction" >&2
                return 1
        end
    case "cycle-stack-padding"
        set direction $argv[1]
        set -e argv[1]

        # Stack padding fractions cycle in this order. Edit to tune.
        set -l pad_fracs (math "2/3") (math "1/2")

        set cfg_tp (yabai -m config top_padding | string trim)
        set cfg_bp (yabai -m config bottom_padding | string trim)
        set cfg_lp (yabai -m config left_padding | string trim)
        set cfg_rp (yabai -m config right_padding | string trim)

        yabai -m query --windows --window | jq -r '.frame | "\(.x)\n\(.y)\n\(.w)\n\(.h)"' | read --line win_x win_y win_w win_h
        yabai -m query --displays --display | jq -r '.frame | "\(.x)\n\(.y)\n\(.w)\n\(.h)"' | read --line dsp_x dsp_y dsp_w dsp_h

        # Detect if window is on the target side
        set -l on_side false
        set -l dim_ratio 0
        switch "$direction"
            case west east
                set dim_ratio (math "$win_w / $dsp_w")
            case north south
                set dim_ratio (math "$win_h / $dsp_h")
        end
        switch "$direction"
            case west
                test (math "round(0.05 * $dsp_w - ($win_x - $dsp_x))") -gt 0; and set on_side true
            case east
                test (math "round(0.05 * $dsp_w - ($dsp_x + $dsp_w - $win_x - $win_w))") -gt 0; and set on_side true
            case north
                test (math "round(0.05 * $dsp_h - ($win_y - $dsp_y))") -gt 0; and set on_side true
            case south
                test (math "round(0.05 * $dsp_h - ($dsp_y + $dsp_h - $win_y - $win_h))") -gt 0; and set on_side true
        end

        # Cycle through pad_fracs: match current ratio → advance to next
        set -l frac $pad_fracs[1]
        if test "$on_side" = true
            set -l n (count $pad_fracs)
            for i in (seq $n)
                set -l diff (math "round(abs($dim_ratio - $pad_fracs[$i]) * 1000)")
                if test "$diff" -lt 50
                    set -l next (math "$i % $n + 1")
                    set frac $pad_fracs[$next]
                    break
                end
            end
        end

        # Convert frac to padding: the "big" padding pushes the stack to occupy $frac of the display
        set -l big 0
        switch "$direction"
            case west east
                set big (math "floor($dsp_w * (1 - $frac))")
            case north south
                set big (math "floor($dsp_h * (1 - $frac))")
        end

        switch "$direction"
            case west
                yabai -m space --padding "abs:$cfg_tp:$cfg_bp:$cfg_lp:$big"
            case east
                yabai -m space --padding "abs:$cfg_tp:$cfg_bp:$big:$cfg_rp"
            case north
                yabai -m space --padding "abs:$cfg_tp:$big:$cfg_lp:$cfg_rp"
            case south
                yabai -m space --padding "abs:$big:$cfg_bp:$cfg_lp:$cfg_rp"
        end
    case "get-stack-padding"
        yabai -m query --windows --window | jq -r '.frame | "\(.x)\n\(.y)\n\(.w)\n\(.h)"' | read --line win_x win_y win_w win_h
        osascript -l JavaScript -e "
            ObjC.import('AppKit');
            var wx = $win_x, wy = $win_y;
            var screens = \$.NSScreen.screens;
            var s = \$.NSScreen.mainScreen;
            for (var i = 0; i < screens.count; i++) {
                var sf = screens.objectAtIndex(i).frame;
                if (wx >= sf.origin.x && wx < sf.origin.x + sf.size.width) { s = screens.objectAtIndex(i); break; }
            }
            var f = s.frame;
            var vf = s.visibleFrame;
            var y = f.size.height - vf.origin.y - vf.size.height + f.origin.y;
            [Math.round(vf.origin.x), Math.round(y), Math.round(vf.size.width), Math.round(vf.size.height)].join('\n');
        " | read --line dsp_x dsp_y dsp_w dsp_h

        set tp (math "round($win_y - $dsp_y)")
        set bp (math "round($dsp_y + $dsp_h - $win_y - $win_h)")
        set lp (math "round($win_x - $dsp_x)")
        set rp (math "round($dsp_x + $dsp_w - $win_x - $win_w)")
        echo "$tp:$bp:$lp:$rp"
    case "set-stack-default-padding"
        set tp (yabai -m config top_padding | string trim)
        set bp (yabai -m config bottom_padding | string trim)
        set lp (yabai -m config left_padding | string trim)
        set rp (yabai -m config right_padding | string trim)

        set -l current (yabai-preset get-stack-padding)
        or begin
            yabai -m space --padding "abs:$tp:$bp:$lp:$rp"
            return
        end

        set -l needs_reset false
        set -l defaults $tp $bp $lp $rp
        set -l vals (string split : $current)
        for i in (seq (count $defaults))
            if test (math "round(abs($vals[$i] - $defaults[$i]))") -gt 5
                set needs_reset true
                break
            end
        end

        if test "$needs_reset" = true
            yabai -m space --padding "abs:$tp:$bp:$lp:$rp"
        end
    case "snap-center"
        # Centered snap modes: "width_frac:height_frac". Edit to tune.
        set -l center_modes "1:1" "0.75:0.75" "2/3:1" "1/3:1"

        set gap (yabai -m config window_gap | string trim)
        set tp (yabai -m config top_padding | string trim)
        set bp (yabai -m config bottom_padding | string trim)
        set lp (yabai -m config left_padding | string trim)
        set rp (yabai -m config right_padding | string trim)

        yabai -m query --windows --window | jq -r '.frame | "\(.x)\n\(.y)\n\(.w)\n\(.h)"' | read --line win_x win_y win_w win_h
        osascript -l JavaScript -e "
            ObjC.import('AppKit');
            var wx = $win_x, wy = $win_y;
            var screens = \$.NSScreen.screens;
            var s = \$.NSScreen.mainScreen;
            for (var i = 0; i < screens.count; i++) {
                var sf = screens.objectAtIndex(i).frame;
                if (wx >= sf.origin.x && wx < sf.origin.x + sf.size.width) { s = screens.objectAtIndex(i); break; }
            }
            var f = s.frame;
            var vf = s.visibleFrame;
            var y = f.size.height - vf.origin.y - vf.size.height + f.origin.y;
            [Math.round(vf.origin.x), Math.round(y), Math.round(vf.size.width), Math.round(vf.size.height)].join('\n');
        " | read --line dsp_x dsp_y dsp_w dsp_h

        set -l uw (math "$dsp_w - $lp - $rp")
        set -l uh (math "$dsp_h - $tp - $bp")
        set -l w_ratio (math "$win_w / $uw")
        set -l h_ratio (math "$win_h / $uh")

        # Cycle: match current mode → advance to next
        set -l target_w 1
        set -l target_h 1
        set -l n (count $center_modes)
        for i in (seq $n)
            echo $center_modes[$i] | read -d: mode_w_raw mode_h_raw
            set -l mw (math "$mode_w_raw")
            set -l mh (math "$mode_h_raw")
            set -l dw (math "round(abs($w_ratio - $mw) * 1000)")
            set -l dh (math "round(abs($h_ratio - $mh) * 1000)")
            if test "$dw" -lt 80 -a "$dh" -lt 80
                set -l next_i (math "$i % $n + 1")
                echo $center_modes[$next_i] | read -d: target_w target_h
                break
            end
        end

        set -l tw (math "$target_w")
        set -l th (math "$target_h")
        set -l w (math "floor($uw * $tw)")
        set -l h (math "floor($uh * $th)")
        set -l x (math "floor($dsp_x + $lp + ($uw - $w) / 2)")
        set -l y (math "floor($dsp_y + $tp + ($uh - $h) / 2)")

        yabai -m window --move "abs:$x:$y"
        yabai -m window --resize "abs:$w:$h"
    case "cycle-stack-center"
        # Centered stack modes: "width_frac:height_frac". Edit to tune.
        set -l center_modes "1:1" "0.75:0.75" "2/3:1" "1/3:1"

        set cfg_tp (yabai -m config top_padding | string trim)
        set cfg_bp (yabai -m config bottom_padding | string trim)
        set cfg_lp (yabai -m config left_padding | string trim)
        set cfg_rp (yabai -m config right_padding | string trim)

        yabai -m query --windows --window | jq -r '.frame | "\(.w)\n\(.h)"' | read --line win_w win_h
        yabai -m query --displays --display | jq -r '.frame | "\(.w)\n\(.h)"' | read --line dsp_w dsp_h

        set -l w_ratio (math "$win_w / $dsp_w")
        set -l h_ratio (math "$win_h / $dsp_h")

        # Cycle: match current mode → advance to next
        set -l target_w 1
        set -l target_h 1
        set -l n (count $center_modes)
        for i in (seq $n)
            echo $center_modes[$i] | read -d: mode_w_raw mode_h_raw
            set -l mw (math "$mode_w_raw")
            set -l mh (math "$mode_h_raw")
            set -l dw (math "round(abs($w_ratio - $mw) * 1000)")
            set -l dh (math "round(abs($h_ratio - $mh) * 1000)")
            if test "$dw" -lt 80 -a "$dh" -lt 80
                set -l next_i (math "$i % $n + 1")
                echo $center_modes[$next_i] | read -d: target_w target_h
                break
            end
        end

        set -l tw (math "$target_w")
        set -l th (math "$target_h")
        if test "$tw" = 1 -a "$th" = 1
            yabai -m space --padding "abs:$cfg_tp:$cfg_bp:$cfg_lp:$cfg_rp"
        else
            set -l h_pad (math "floor($dsp_w * (1 - $tw) / 2)")
            if test "$th" = 1
                yabai -m space --padding "abs:$cfg_tp:$cfg_bp:$h_pad:$h_pad"
            else
                set -l v_pad (math "floor($dsp_h * (1 - $th) / 2)")
                yabai -m space --padding "abs:$v_pad:$v_pad:$h_pad:$h_pad"
            end
        end
    case "get-app-window-id"
        argparse 'match-title=' -- $argv
        or return 1

        set app_name $argv[1]
        set -e argv[1]

        # Accept path or name
        if string match -q "*.app" "$app_name"
            set app_name (path basename "$app_name" | path change-extension '')
        end

        set -l title_filter 'true'
        set -l jq_title_args
        if set -q _flag_match_title
            set title_filter '(.title | test($title_re))'
            set jq_title_args --arg title_re "$_flag_match_title"
        end

        set current_space (yabai -m query --spaces --space | jq '.index')

        # Find best window: prefer non-minimized, prefer current space
        yabai -m query --windows \
        | jq -re $jq_title_args --arg app "$app_name" --argjson cs "$current_space" '
            [.[] | select(.app == $app) | select('"$title_filter"')]
            | if length == 0 then error("no windows") else . end
            | sort_by([
                (if ."is-minimized" then 1 else 0 end),
                (if .space == $cs then 0 else 1 end)
            ])
            | first
            | .id
        '
    case "focus-app"
        argparse 'match-title=' -- $argv
        or return 1

        set app_name $argv[1]
        set -e argv[1]

        set -l match_title_args
        if set -q _flag_match_title
            set match_title_args --match-title "$_flag_match_title"
        end

        set window (yabai-preset get-app-window-id $match_title_args "$app_name")
        or begin
            open -a "$app_name"
            return
        end

        set current_space (yabai -m query --spaces --space | jq '.index')

        yabai -m query --windows --window "$window" \
        | jq -re '"\(.space):\(."is-minimized")"' \
        | read -d: target_space is_minimized

        if test "$is_minimized" = "true"
            yabai -m window "$window" --deminimize
        end

        if test "$target_space" != "$current_space"
            yabai-preset focus-space "$target_space"
        end

        yabai -m window "$window" --focus
    case "alternate-window"
        # Toggle a single window: minimize it when it's already focused,
        # otherwise focus it (restoring if minimized). Identify the window by
        # --id or by a --title regex (preferring non-minimized on the current
        # space when several match).
        argparse 'id=' 'title=' -- $argv
        or return 1

        set window "$_flag_id"
        if test -z "$window"
            set -q _flag_title
            or begin
                echo "alternate-window: --id or --title required" >&2
                return 1
            end

            set current_space (yabai -m query --spaces --space | jq '.index')
            set window (yabai -m query --windows \
                | jq -re --arg title_re "$_flag_title" --argjson cs "$current_space" '
                    [.[] | select(.title | test($title_re))]
                    | if length == 0 then error("no windows") else . end
                    | sort_by([
                        (if ."is-minimized" then 1 else 0 end),
                        (if .space == $cs then 0 else 1 end)
                    ])
                    | first
                    | .id')
            or return 1
        end

        # Read the focused window id first (hs sees the floating terminal, which
        # yabai doesn't), then collapse the floating terminal in the background
        # so it doesn't hover in front of whatever we focus next.
        set focused (hs-preset get-floatingterm-or-focused-window-id)
        iterm-preset hide-floating-terminal &
        disown
        if test "$focused" = "$window"
            yabai-preset minimize "$window"
        else
            yabai-preset focus-window-id "$window"
        end
    case "get-focused-display"
        yabai -m query --windows --window 2>/dev/null | jq -r '.display // empty'
    case "list-windows"
        argparse 'regex=' -- $argv
        or return 1

        yabai -m query --windows | jq -cer --arg regex "$_flag_regex" '
            .[] | select(."is-visible" and (."is-sticky" | not) and (.title | test($regex)))'
    case "list-visible-windows"
        # List windows that have a significant fraction of their area actually
        # shown in the foreground (not covered by windows above them). Reuses the
        # same occlusion math as get-visible-window-id.
        # Usage: list-visible-windows [--threshold FRAC] [--regex RE]
        #   --threshold  minimum visible fraction to include (default 0.05)
        #   --regex      only include windows whose title matches RE
        argparse 'threshold=' 'regex=' -- $argv
        or return 1
        set threshold (test -n "$_flag_threshold"; and echo "$_flag_threshold"; or echo 0.05)
        set regex (test -n "$_flag_regex"; and echo "$_flag_regex"; or echo '')

        yabai -m query --windows --space | jq -cer --argjson threshold "$threshold" --arg regex "$regex" '
        def hidden($under; $above):
        ($under.x >= $above.x
        and ($under.x + $under.w) <=($above.x + $above.w)
        and $under.y >= $above.y
        and ($under.y + $under.h) <= ($above.y + $above.h));

        def intersect($u; $a):
        if
                ($u.x >= ($a.x + $a.w)
                or ($u.x + $u.w) <= $a.x
                or ($u.y + $u.h) <= $a.y
                or $u.y >= ($a.y + $a.h)) then empty
        else
                ([$u.x, $a.x] | max) as $x
                | ([$u.y, $a.y] | max) as $y
                | (([$u.x + $u.w, $a.x + $a.w] | min) - $x) as $w
                | (([$u.y + $u.h, $a.y + $a.h] | min) - $y) as $h
                | {$x, $y, $w, $h}
        end;

        def visible_area($under_list; $many):
        $under_list
        | [.[0], .[1:]] as [$under, $tail]
        | if $under == null then 0
        elif ($many | any(hidden($under; .))) then visible_area($tail; $many)
        else (
                [first($many[] | intersect($under; .))] as [$i]
                | $under as $u
                | if $i == null then (($u.w * $u.h) + visible_area($tail; $many))
                else visible_area(([
                        {x: $u.x, y: $u.y, w: ($i.x - $u.x), h: ($i.y - $u.y)},
                        {x: $i.x, y: $u.y, w: $i.w, h: ($i.y - $u.y)},
                        {x: ($i.x + $i.w), y: $u.y, w: ($u.x + $u.w - $i.x - $i.w), h: ($i.y - $u.y)},
                        {x: $u.x, y: $i.y, w: ($i.x - $u.x), h: $i.h},
                        {x: $i.x, y: $i.y, w: $i.w, h: $i.h},
                        {x: ($i.x + $i.w), y: $i.y, w: ($u.x + $u.w - $i.x - $i.w), h: $i.h},
                        {x: $u.x, y: ($i.y + $i.h), w: ($i.x - $u.x), h: ($u.y + $u.h - $i.y - $i.h)},
                        {x: $i.x, y: ($i.y + $i.h), w: $i.w, h: ($u.y + $u.h - $i.y - $i.h)},
                        {x: ($i.x + $i.w), y: ($i.y + $i.h), w: ($u.x + $u.w - $i.x - $i.w), h: ($u.y + $u.h - $i.y - $i.h)}
                ]|map(select((.h>0) and (.w>0)))) + $tail; $many) end
        )
        end;
        .
        | map(select(."is-visible" and (."is-sticky"|not) and (.title | test($regex))))
        | reverse
        | with_entries(.value += {z_index: .key} | .key |= "key_\(.)")
        | to_entries
        | map(.value)
        | { under: .[0], many: .[1:] }
        | [recurse({ under: .many[0], many: .many[1:] }; .under != null)]
        | map(select(.under != null))
        | map(.under.visible_area = visible_area([.under.frame + {title: .under.title}]; .many|map(.frame)))
        | map(.under)
        | map(select((.frame|.w*.h) > 0))
        | map(.percentage_visible = (.visible_area / (.frame|.w*.h)))
        | map(select(.percentage_visible >= $threshold))
        | sort_by(-.z_index)
        | .[]'
        or return 1
    case "*"
        echo "command not found - $preset"
        return 1
    end
end

yabai-preset $argv
