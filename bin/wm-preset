#!/usr/bin/env -S fish --no-config
set -x PATH /opt/homebrew/bin (status dirname) $PATH

function wm-preset
    if pgrep -xq AeroSpace
        aerospace-preset $argv
        return $status
    else if pgrep -xq yabai
        yabai-preset $argv
        return $status
    else
        echo "No window manager running" >&2
        return 1
    end
end

wm-preset $argv
