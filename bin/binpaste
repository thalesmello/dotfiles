#!/bin/sh

# Paste the file on the macOS clipboard into a folder (a copy). Pairs with
# `bincopy`.
#
#   binpaste ~/Downloads   # copy the clipboard's file into the folder

set -e

if [ -z "$1" ]; then
    echo "usage: binpaste <foldername>" >&2
    exit 1
fi

folder="$(realpath "$1")"

osascript -e "tell application \"Finder\" to duplicate ((the clipboard as «class furl») as alias) to (POSIX file \"$folder\" as alias)"
