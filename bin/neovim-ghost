#!/opt/homebrew/bin/fish --no-config
set -x PATH /opt/homebrew/bin (status dirname) $PATH

function neovim-ghost
    set preset $argv[1]
    set -e argv[1]

    switch "$preset"
    case "is-alive"
        pgrep -q -F "$TMPDIR/nvim_ghost.pid"
        return $status
    case "focus"
        yabai-preset focus-pid "$(cat "$TMPDIR/nvim_ghost.pid")"
    case "start"
        argparse spawn=? -- $argv

        if set -q _flag_spawn
            nohup (status filename) start &>/dev/null &
        else
            display-message "Start GHOST"
            env NVIM_GHOST_ENABLE=1 neovide --frame buttonless --title-hidden -- --listen "$TMPDIR/nvim_ghost.socket" &
            echo "$last_pid" > "$TMPDIR/nvim_ghost.pid"
            wait
            rm "$TMPDIR/nvim_ghost.pid"
        end
    case "trigger"
        if neovim-ghost is-alive
            neovim-ghost focus
        else
            neovim-ghost start --spawn
        end;
    case "focus-or-new-tab"
        set skip_focus 0
        if not neovim-ghost is-alive
            neovim-ghost start --spawn
            sleep 2
            set skip_focus 1
        end

        nvr --nostart --servername "$TMPDIR/nvim_ghost.socket" -c "lua require'vim_utils'.focus_or_new_tab [[$argv]]"

        if test "$skip_focus" != 1
            neovim-ghost focus
        end
    case "edit"
        argparse --stop-nonopt delete-hidden no-wait close-on-cmd-enter close-minimize-on-cmd-enter -- $argv
        set skip_focus 0

        if not neovim-ghost is-alive
            neovim-ghost start --spawn
            set skip_focus 1
        end

        set -l remote_arg --remote-tab-wait
        if set -q _flag_no_wait
            set remote_arg --remote-tab
        end

        set -l bufhidden_args
        if set -q _flag_delete_hidden
            set bufhidden_args +"set bufhidden=delete"
        end

        set -l close_map_args
        if set -q _flag_close_minimize_on_cmd_enter
            # Minimize the neovide window (pid read from the file at keypress time
            # by the shell) then write+close, so it only happens on cmd+enter.
            set -l minimize_cmd "call system('yabai-preset minimize-pid \$(cat $TMPDIR/nvim_ghost.pid)')"
            set close_map_args +"nnoremap <buffer> <D-CR> <Cmd>$minimize_cmd<CR>ZZ" +"inoremap <buffer> <D-CR> <Esc><Cmd>$minimize_cmd<CR>ZZ"
        else if set -q _flag_close_on_cmd_enter
            set close_map_args +"nnoremap <buffer> <D-CR> ZZ" +"inoremap <buffer> <D-CR> <Esc>ZZ"
        end

        nvr --nostart --servername "$TMPDIR/nvim_ghost.socket" $remote_arg $bufhidden_args $close_map_args $argv &

        if test "$skip_focus" != 1
            neovim-ghost focus
        end

        wait

    case "kill"
        kill -9 "$(cat "$TMPDIR/nvim_ghost.pid")"
        rm "$TMPDIR/nvim_ghost.pid"
        rm "$TMPDIR/nvim_ghost.socket"
    case "*"
        echo "invalid preset $preset" >&2
    end
end

neovim-ghost $argv
