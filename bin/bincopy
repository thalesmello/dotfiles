#!/bin/sh

# Copy a file onto the macOS clipboard as a real file reference, so it pastes
# straight into Finder, Mail, Messages, etc. Pairs with `binpaste`/`binmove`.
#
#   bincopy photo.png      # copy the file itself

set -e

if [ -z "$1" ]; then
    echo "usage: bincopy <filename>" >&2
    exit 1
fi

file="$(realpath "$1")"

osascript \
    -e 'on run argv' \
    -e 'set the clipboard to item 1 of argv as «class furl»' \
    -e 'end run' \
    "$file"
